#!/usr/bin/env bash
# vmigrate destination-side helper
set -Eeuo pipefail

VERSION="1.0.1"
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
CONFIG_FILE="${VMIGRATE_CONFIG:-${SCRIPT_DIR}/vmigrate.env}"

RED=$'\033[0;31m'; GREEN=$'\033[0;32m'; YELLOW=$'\033[1;33m'; BLUE=$'\033[0;34m'; NC=$'\033[0m'
if [[ -n "${NO_COLOR:-}" ]]; then
  RED=""; GREEN=""; YELLOW=""; BLUE=""; NC=""
fi
info(){ echo "${BLUE}>>${NC} $*"; }
ok(){ echo "${GREEN}OK${NC} $*"; }
warn(){ echo "${YELLOW}WARN${NC} $*"; }
die(){ echo "${RED}ERROR${NC} $*" >&2; exit 1; }
need(){ command -v "$1" >/dev/null 2>&1 || die "Required command not found: $1"; }

usage(){ cat <<EOF
vmigrate-agent v${VERSION}

Usage:
  ./vmigrate-agent version
  ./vmigrate-agent discover [TARGET_ID]
  ./vmigrate-agent discover Target ID --yes
  ./vmigrate-agent init
  ./vmigrate-agent show
  ./vmigrate-agent handoff
  ./vmigrate-agent quick [TARGET_ID]
  ./vmigrate-agent doctor
  ./vmigrate-agent export
  ./vmigrate-agent close
  ./vmigrate-agent boot
  ./vmigrate-agent status

Recommended first run:
  ./vmigrate-agent quick 2672
EOF
}

ask(){ local var="$1" prompt="$2" def="${3:-}" val; read -r -p "$prompt${def:+ [$def]}: " val; printf -v "$var" '%s' "${val:-$def}"; }
confirm(){ local prompt="$1" ans; read -r -p "$prompt [yes/no]: " ans; [[ "$ans" == "yes" ]]; }
ask_yes_default(){
  local prompt="$1" ans
  while true; do
    read -r -p "$prompt [Y/n]: " ans
    case "$ans" in
      ""|Y|y) return 0 ;;
      N|n) return 1 ;;
      *) echo "Please answer Y or N." ;;
    esac
  done
}

get_conf(){ local key="$1"; [[ -f "$CONFIG_FILE" ]] || return 0; awk -F= -v k="$key" '$1==k {print substr($0, index($0,"=")+1); exit}' "$CONFIG_FILE"; }

load_config(){
  [[ -f "$CONFIG_FILE" ]] || die "Config not found: $CONFIG_FILE. Run: ./vmigrate-agent discover TARGET_ID"
  # shellcheck disable=SC1090
  source "$CONFIG_FILE"
  : "${VM_NAME:?}"; : "${TARGET_ID:?}"; : "${TARGET_DISK:?}"
  NBD_PORT="${NBD_PORT:-10809}"
  NBD_EXPORT="${NBD_EXPORT:-vm-${TARGET_ID}}"
}

init_config(){
  local vm vmid disk nbd_port nbd_export
  ask vm "Source VM name / display name" "kvm3023"
  ask vmid "Target ID" "2672"
  ask disk "Target disk path" "/dev/pve/vm-${vmid}-disk-0"
  ask nbd_port "NBD port" "10809"
  ask nbd_export "NBD export name" "vm-${vmid}"
  cat > "$CONFIG_FILE" <<EOF
VM_NAME=$vm
TARGET_ID=$vmid
TARGET_DISK=$disk
NBD_PORT=$nbd_port
NBD_EXPORT=$nbd_export
EOF
  chmod 600 "$CONFIG_FILE"
  ok "Config written: $CONFIG_FILE"
}

vm_name_from_qm(){
  local vmid="$1" name
  name="$(qm config "$vmid" 2>/dev/null | awk -F': ' '$1=="name" {print $2; exit}')"
  [[ -n "$name" ]] || name="kvm${vmid}"
  printf '%s' "$name"
}

lvm_path_for_lv(){
  local lv="$1"
  command -v lvs >/dev/null 2>&1 || return 0
  lvs --noheadings -o vg_name,lv_name 2>/dev/null | awk -v lv="$lv" '$2==lv {print "/dev/" $1 "/" $2; exit}'
}

lvm_path_for_vmid(){
  local vmid="$1"
  command -v lvs >/dev/null 2>&1 || return 0
  lvs --noheadings -o vg_name,lv_name 2>/dev/null | awk -v vmid="$vmid" '
    $2 ~ ("^vm-" vmid "-") {print "/dev/" $1 "/" $2; exit}
    $2 ~ vmid {fallback="/dev/" $1 "/" $2}
    END {if (fallback != "") print fallback}'
}

first_disk_from_qm(){
  local vmid="$1" vol disk lv
  vol="$(qm config "$vmid" 2>/dev/null | awk -F': ' '
    $1 ~ /^(scsi|virtio|sata|ide)[0-9]+$/ {
      split($2,a,",");
      print a[1];
      exit
    }')"

  if [[ -n "$vol" ]]; then
    if [[ "$vol" == /* ]]; then
      printf '%s' "$vol"
      return 0
    fi
    if [[ "$vol" == *:* ]]; then
      lv="${vol#*:}"
      disk="$(lvm_path_for_lv "$lv")"
      if [[ -n "$disk" ]]; then
        printf '%s' "$disk"
        return 0
      fi
    fi
  fi

  disk="$(lvm_path_for_vmid "$vmid")"
  if [[ -n "$disk" ]]; then
    printf '%s' "$disk"
    return 0
  fi

  printf '/dev/pve/vm-%s-disk-0' "$vmid"
}

discover_config(){
  local vmid_arg="${1:-}" yes_arg="${2:-}" vmid vm_name disk nbd_port nbd_export yes_mode=0
  need qm
  vmid="$vmid_arg"
  [[ "$vmid" == "--yes" ]] && vmid="" && yes_arg="--yes"
  [[ "$yes_arg" == "--yes" || "${VMIGRATE_YES:-}" == "1" ]] && yes_mode=1
  [[ -n "$vmid" ]] || ask vmid "Target ID" "2672"
  qm config "$vmid" >/dev/null 2>&1 || warn "qm config failed for Target ID $vmid; continuing with manual/default values"
  vm_name="$(vm_name_from_qm "$vmid")"
  disk="$(first_disk_from_qm "$vmid")"
  nbd_port="$(get_conf NBD_PORT)"; [[ -n "$nbd_port" ]] || nbd_port="10809"
  nbd_export="vm-${vmid}"

  cat <<EOF

Detected destination values
---------------------------
Config file    : $CONFIG_FILE
Target ID      : $vmid
VM name        : $vm_name
Disk           : $disk
NBD port       : $nbd_port
NBD export     : $nbd_export
EOF

  if [[ "$yes_mode" == "1" ]] || confirm "Write these values to destination config?"; then
    cat > "$CONFIG_FILE" <<EOF
VM_NAME=$vm_name
TARGET_ID=$vmid
TARGET_DISK=$disk
NBD_PORT=$nbd_port
NBD_EXPORT=$nbd_export
EOF
    chmod 600 "$CONFIG_FILE"
    ok "Config written: $CONFIG_FILE"
  else
    warn "Config not changed"
  fi
}

show_config(){
  load_config
  cat <<EOF
Destination target
------------------
VM name/export : $VM_NAME
Target ID      : $TARGET_ID
Disk           : $TARGET_DISK
NBD            : 127.0.0.1:${NBD_PORT}, export=${NBD_EXPORT}
EOF
}

handoff_token(){
  load_config
  need base64
  {
    printf 'TARGET_ID=%s\n' "$TARGET_ID"
    printf 'TARGET_DISK=%s\n' "$TARGET_DISK"
    printf 'NBD_PORT=%s\n' "$NBD_PORT"
    printf 'NBD_EXPORT=%s\n' "$NBD_EXPORT"
  } | base64 | tr -d '\r\n' | sed 's/^/VMIGRATE_HANDOFF_V1:/'
}

quick_start(){
  local vmid_arg="${1:-}" token

  if [[ -n "$vmid_arg" || ! -f "$CONFIG_FILE" ]]; then
    discover_config "$vmid_arg"
  else
    info "Using existing destination config: $CONFIG_FILE"
  fi

  load_config
  token="$(handoff_token)"

  cat <<EOF

Target quick summary
-------------------------
Config file    : $CONFIG_FILE
Target ID      : $TARGET_ID
Disk           : $TARGET_DISK
NBD port       : $NBD_PORT
NBD export     : $NBD_EXPORT

Handoff token
-------------
$token

Recommended quick path
----------------------
1) On source, use the handoff token and let quick discover the source VM:
./vmigrate quick '$token'

2) On destination, start the NBD export:
./vmigrate-agent doctor
./vmigrate-agent export

3) On source, continue with the commands printed by quick/next:
./vmigrate tunnel
./vmigrate tunnel-check
./vmigrate attach-target
./vmigrate check-target
./vmigrate bitmap
./vmigrate check-bitmap
./vmigrate full
./vmigrate wait-full
./vmigrate report

4) For cutover, run on source:
./vmigrate cutover-check
./vmigrate final
./vmigrate report
./vmigrate stop-source

5) After source final/stop-source succeeds, run on destination:
./vmigrate-agent close
./vmigrate-agent boot
EOF
}

port_in_use(){ ss -lntp | grep -q "127.0.0.1:${NBD_PORT}"; }

preflight(){
  load_config; need qm; need qemu-nbd; need ss
  qm config "$TARGET_ID" >/dev/null 2>&1 || warn "Target ID $TARGET_ID not found in qm; disk-only export may still work"
  [[ -b "$TARGET_DISK" || -f "$TARGET_DISK" ]] || die "Target disk not found: $TARGET_DISK"
  if port_in_use; then die "NBD port already in use: 127.0.0.1:${NBD_PORT}"; fi
  ok "Destination doctor checks passed"
}

status(){
  load_config
  qm status "$TARGET_ID" 2>/dev/null || true
  pgrep -a qemu-nbd || true
  ss -lntp | grep "$NBD_PORT" || true
  [[ -e "$TARGET_DISK" ]] && blockdev --getsize64 "$TARGET_DISK" 2>/dev/null || true
}

export_disk(){
  load_config; need qemu-nbd; need ss
  local qm_out target_status
  [[ -b "$TARGET_DISK" || -f "$TARGET_DISK" ]] || die "Target disk not found: $TARGET_DISK"
  if command -v qm >/dev/null 2>&1; then
    if qm_out="$(qm status "$TARGET_ID" 2>/dev/null)"; then
      target_status="$(printf '%s\n' "$qm_out" | awk -F': ' '$1=="status" {print $2; exit}')"
      if [[ "$target_status" == "running" ]]; then
        if [[ "${VMIGRATE_ALLOW_STOP_TARGET:-0}" == "1" ]]; then
          warn "VMIGRATE_ALLOW_STOP_TARGET=1 set; stopping running target VM $TARGET_ID before export"
          qm stop "$TARGET_ID" || die "Failed to stop running target VM $TARGET_ID"
        elif [[ -t 0 ]]; then
          warn "Target VM $TARGET_ID is running. Exporting a running destination disk is unsafe."
          if ask_yes_default "Stop target VM $TARGET_ID now and continue export?"; then
            qm stop "$TARGET_ID" || die "Failed to stop running target VM $TARGET_ID"
          else
            die "Target VM $TARGET_ID is running. Refusing to export its disk."
          fi
        else
          die "Target VM $TARGET_ID is running. Refusing to export its disk. Stop it manually or set VMIGRATE_ALLOW_STOP_TARGET=1 to allow vmigrate-agent export to stop it."
        fi
      fi
    else
      warn "Target ID $TARGET_ID not found by qm status; continuing with disk export only"
    fi
  else
    warn "qm command not found; continuing with disk export only"
  fi
  if port_in_use; then
    die "NBD port already in use: 127.0.0.1:${NBD_PORT}"
  fi
  pgrep -a qemu-nbd || true
  info "Starting qemu-nbd on 127.0.0.1:${NBD_PORT} export=${NBD_EXPORT} disk=${TARGET_DISK}"
  qemu-nbd -t --fork -b 127.0.0.1 -p "$NBD_PORT" -x "$NBD_EXPORT" -f raw "$TARGET_DISK"
  sleep 1
  port_in_use || die "qemu-nbd did not start"
  ok "NBD export is ready"
}

close_export(){
  load_config
  pkill -f "qemu-nbd.*${NBD_PORT}.*${NBD_EXPORT}" >/dev/null 2>&1 || true
  pkill -f "qemu-nbd.*${TARGET_DISK}" >/dev/null 2>&1 || true
  sleep 1
  ss -lntp | grep "$NBD_PORT" && warn "Port still appears open" || ok "NBD export closed"
}

boot_vm(){
  load_config
  close_export || true
  qm start "$TARGET_ID"
  ok "Boot command sent for Target ID $TARGET_ID"
}

cmd="${1:-}"; shift || true
case "$cmd" in
  version) echo "vmigrate-agent ${VERSION}" ;;
  discover) discover_config "${1:-}" "${2:-}" ;;
  init) init_config ;;
  show) show_config ;;
  handoff) handoff_token ;;
  quick) quick_start "${1:-}" ;;
  doctor) preflight ;;
  export) export_disk ;;
  close) close_export ;;
  boot) boot_vm ;;
  status) status ;;
  -h|--help|help|"") usage ;;
  *) usage; die "Unknown command: $cmd" ;;
esac
