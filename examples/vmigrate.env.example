# vmigrate QMP migration config
# Copy this file to vmigrate.env on both source and destination hosts.

VM_NAME=kvm3023
SRC_DISK=/dev/centos/kvm3023_img

# Auto-filled by ./vmigrate discover
QEMU_DEVICE=
QEMU_NODE=

# VM-specific names avoid conflicts during retries/debugging.
BITMAP=vmigrate-bitmap-kvm3023
TARGET_NODE=vmigrate-target-kvm3023

TARGET_HOST=CHANGE_ME
TARGET_SSH_USER=root
TARGET_SSH_PORT=22
TARGET_ID=2672
TARGET_DISK=/dev/pve/vm-2672-disk-0

NBD_PORT=10809
NBD_EXPORT=kvm3023
TUNNEL_MODE=autossh
AUTOSSH_MONITOR_PORT=20000
