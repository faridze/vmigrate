apply_handoff(){
  local token="${1:-}" prefix="VMIGRATE_HANDOFF_V1:" payload decoded line key val
  local handoff_target_id="" handoff_target_disk="" handoff_nbd_port="" handoff_nbd_export=""

  [[ -n "$token" ]] || die "Missing handoff token"
  [[ "$token" == "$prefix"* ]] || die "Invalid handoff token prefix"
  need base64

  payload="${token#"$prefix"}"
  [[ -n "$payload" ]] || die "Missing handoff payload"
  decoded="$(printf '%s' "$payload" | base64 -d 2>/dev/null)" || die "Failed to decode handoff payload"

  while IFS= read -r line || [[ -n "$line" ]]; do
    [[ -n "$line" ]] || continue
    [[ "$line" == *=* ]] || continue
    key="${line%%=*}"
    val="${line#*=}"
    case "$key" in
      TARGET_ID) handoff_target_id="$val" ;;
      TARGET_DISK) handoff_target_disk="$val" ;;
      NBD_PORT) handoff_nbd_port="$val" ;;
      NBD_EXPORT) handoff_nbd_export="$val" ;;
      *) ;;
    esac
  done <<EOF
$decoded
EOF

  [[ -n "$handoff_target_id" ]] || die "Handoff payload missing TARGET_ID"
  [[ -n "$handoff_target_disk" ]] || die "Handoff payload missing TARGET_DISK"
  [[ -n "$handoff_nbd_port" ]] || handoff_nbd_port="10809"
  [[ -n "$handoff_nbd_export" ]] || handoff_nbd_export="vm-${handoff_target_id}"

  write_key TARGET_ID "$handoff_target_id"
  write_key TARGET_DISK "$handoff_target_disk"
  write_key NBD_PORT "$handoff_nbd_port"
  write_key NBD_EXPORT "$handoff_nbd_export"

  cat <<EOF
Applied handoff
---------------
TARGET_ID=$handoff_target_id
TARGET_DISK=$handoff_target_disk
NBD_PORT=$handoff_nbd_port
NBD_EXPORT=$handoff_nbd_export
EOF
}

remote_dir(){
  local rdir
  rdir="$(get_conf REMOTE_RUN_DIR)"
  if [[ -n "$rdir" ]]; then
    printf '%s\n' "$rdir"
  else
    printf '%s\n' "/root/vmigrate"
  fi
}
remote_ssh(){
  ssh -p "$TARGET_SSH_PORT" -o BatchMode=yes -o ConnectTimeout=8 "$TARGET_SSH_USER@$TARGET_HOST" "$@"
}
remote_ssh_batch(){
  remote_ssh "$@"
}

remote_prepare_next_steps(){
  load_config
  local effective
  effective="$(effective_backup_method)"
  cat <<EOF

Destination is prepared remotely.
Now run:

./vmigrate set-backup-method
./vmigrate doctor
./vmigrate remote-export
./vmigrate tunnel
./vmigrate tunnel-check
EOF
  if [[ "$effective" == "blockdev-backup" ]]; then
    cat <<EOF
./vmigrate attach-target
./vmigrate check-target
EOF
  fi
  cat <<EOF
./vmigrate bitmap
./vmigrate check-bitmap
./vmigrate full
./vmigrate wait-full
./vmigrate report

Optional monitor in another terminal:
./vmigrate watch
EOF
}

remote_prepare(){
  local vm="${1:-}" target_host="${2:-}" target_id="${3:-}" ssh_port="${4:-22}" ssh_user="${5:-root}" show_next="${6:-1}"
  local dst_script rdir token prefix="VMIGRATE_HANDOFF_V1:"

  [[ -n "$vm" && -n "$target_host" && -n "$target_id" ]] || die "Usage: ./vmigrate remote-prepare VM_NAME TARGET_ID TARGET_HOST [SSH_PORT] [SSH_USER]"
  case "$target_id" in *[!0-9]*|'') die "Target ID must be numeric" ;; esac
  case "$ssh_port" in *[!0-9]*|'') die "SSH port must be numeric" ;; esac
  [[ -f "$SCRIPT_DIR/vmigrate" ]] || die "Source helper missing: $SCRIPT_DIR/vmigrate"
  dst_script="$SCRIPT_DIR/vmigrate-agent"
  [[ -f "$dst_script" ]] || die "Destination helper missing: $dst_script"

  write_key VM_NAME "$vm"
  write_key TARGET_HOST "$target_host"
  write_key TARGET_SSH_USER "$ssh_user"
  write_key TARGET_SSH_PORT "$ssh_port"
  write_key TARGET_ID "$target_id"
  if [[ -z "$(get_conf REMOTE_RUN_DIR)" ]]; then
    write_key REMOTE_RUN_DIR "/root/vmigrate/runs/$(sanitize_name "$vm")-${RUN_ID:-$(date '+%Y%m%d-%H%M%S')}"
  fi
  [[ -n "$(get_conf BITMAP)" ]] || write_key BITMAP "$(default_bitmap "$vm")"
  [[ -n "$(get_conf TARGET_NODE)" ]] || write_key TARGET_NODE "$(default_target_node "$vm")"
  [[ -n "$(get_conf NBD_PORT)" ]] || write_key NBD_PORT 10809
  write_key NBD_EXPORT "vm-${target_id}"
  [[ -n "$(get_conf TUNNEL_MODE)" ]] || write_key TUNNEL_MODE autossh
  [[ -n "$(get_conf AUTOSSH_MONITOR_PORT)" ]] || write_key AUTOSSH_MONITOR_PORT 20000
  [[ -n "$(get_conf BACKUP_METHOD)" ]] || write_key BACKUP_METHOD drive-backup

  # shellcheck disable=SC1090
  source "$CONFIG_FILE"
  rdir="$(remote_dir)"

  need ssh
  need scp
  info "Testing SSH connectivity to ${TARGET_SSH_USER}@${TARGET_HOST}:${TARGET_SSH_PORT}"
  remote_ssh_batch true >/dev/null || die "Cannot connect to destination over SSH: ${TARGET_SSH_USER}@${TARGET_HOST}:${TARGET_SSH_PORT}"

  info "Creating remote workspace: $rdir"
  remote_ssh "mkdir -p '$rdir'" || die "Could not create remote workspace: $rdir"

  info "Copying destination helper"
  scp -P "$TARGET_SSH_PORT" -o BatchMode=yes -o ConnectTimeout=8 "$dst_script" "${TARGET_SSH_USER}@${TARGET_HOST}:${rdir}/vmigrate-agent" || die "Could not copy destination helper"
  remote_ssh "chmod +x '$rdir/vmigrate-agent'" || die "Could not make destination helper executable"

  info "Discovering target ID $TARGET_ID"
  remote_ssh "cd '$rdir' && ./vmigrate-agent discover '$TARGET_ID' --yes" || die "Remote destination discover failed"

  info "Reading destination handoff token"
  token="$(remote_ssh "cd '$rdir' && ./vmigrate-agent handoff")" || die "Remote destination handoff failed"
  [[ "$token" == "$prefix"* ]] || die "Remote handoff token is invalid"

  apply_handoff "$token"

  if [[ "${VMIGRATE_AUTO_NBD_PORT:-1}" == "1" ]]; then
    info "Selecting automatic per-run NBD port"
    set_nbd_port auto
  else
    warn "Automatic NBD port selection disabled by VMIGRATE_AUTO_NBD_PORT=0"
  fi

  info "Running source discovery and writing SRC_DISK/QEMU_DEVICE/QEMU_NODE when unambiguous"
  discover "$VM_NAME" --yes
  # shellcheck disable=SC1090
  source "$CONFIG_FILE"
  [[ -n "${SRC_DISK:-}" && ( -b "$SRC_DISK" || -f "$SRC_DISK" ) && -n "${QEMU_DEVICE:-}" && -n "${QEMU_NODE:-}" ]] || die "Source discovery did not write valid SRC_DISK/QEMU_DEVICE/QEMU_NODE. Run: ./vmigrate discover $VM_NAME"
  show_config
  if [[ "$show_next" == "1" ]]; then
    remote_prepare_next_steps
  fi
}

remote_context(){
  echo "Remote run dir : $(remote_dir)"
  echo "Target         : ${TARGET_SSH_USER}@${TARGET_HOST}:${TARGET_SSH_PORT}"
  echo "Target ID      : ${TARGET_ID}"
  echo "NBD            : 127.0.0.1:${NBD_PORT}, export=${NBD_EXPORT}"
}

remote_export_once(){
  local allow_stop="${1:-0}" env_prefix=""
  [[ "$allow_stop" == "1" ]] && env_prefix="VMIGRATE_ALLOW_STOP_TARGET=1 "
  remote_context
  remote_ssh "cd '$(remote_dir)' && ./vmigrate-agent doctor && ${env_prefix}./vmigrate-agent export && ./vmigrate-agent status"
}

remote_nbd_port_free_check(){
  local hit proc
  info "Checking remote NBD port ${NBD_PORT}"

  proc="$(remote_ssh "ps -eo pid=,args= | grep '[q]emu-nbd' | grep -- ' -p ${NBD_PORT} ' || true")" || true
  if [[ -n "$proc" ]]; then
    if printf '%s\n' "$proc" | grep -F -- " -x ${NBD_EXPORT} " >/dev/null && printf '%s\n' "$proc" | grep -F -- "$TARGET_DISK" >/dev/null; then
      ok "Remote NBD export already active for this run"
      remote_context
      remote_ssh "cd '$(remote_dir)' && ./vmigrate-agent status"
      return 2
    fi
    printf '%s\n' "$proc"
    die "Remote NBD port ${NBD_PORT} is already used by another qemu-nbd process. Run remote-dst-close only if this active run owns it, or choose another per-run port with: ./vmigrate set-nbd-port auto."
  fi

  hit="$(remote_ssh "ss -lnt 2>/dev/null | awk '{print \$4}' | grep -E '(^|:)${NBD_PORT}$' || true")" || true
  if [[ -n "$hit" ]]; then
    echo "$hit"
    die "Remote NBD port ${NBD_PORT} is already listening on destination. Run remote-dst-close or choose another per-run port with: ./vmigrate set-nbd-port auto."
  fi

  ok "Remote NBD port is free: ${NBD_PORT}"
}

remote_export(){
  load_config
  need ssh

  if remote_nbd_port_free_check; then
    :
  else
    rc=$?
    [[ "$rc" == "2" ]] && return 0
    return "$rc"
  fi

  local out rc attempt allow_stop=0 did_cleanup=0

  for attempt in 1 2 3; do
    set +e
    out="$(remote_export_once "$allow_stop" 2>&1)"
    rc=$?
    set -e

    printf '%s\n' "$out"

    if [[ "$rc" == "0" ]]; then
      return 0
    fi

    if [[ "$allow_stop" != "1" ]] && printf '%s\n' "$out" | grep -q "Target VM .* is running"; then
      warn "Destination target VM appears to be running."
      if ask_yes_default "Stop the destination VM remotely and retry NBD export?"; then
        allow_stop=1
        continue
      fi
      die "Remote export failed because destination VM is running."
    fi

    if [[ "$did_cleanup" != "1" ]] && printf '%s\n' "$out" | grep -q "NBD port already in use"; then
      warn "Remote NBD export port appears to be already in use: ${NBD_PORT}"
      warn "If another migration owns this port, do not close it. Choose a different per-run port instead: ./vmigrate set-nbd-port auto"
      warn "Current remote run dir: $(remote_dir)"
      if ask_yes_default "Close remote NBD export for this active run, stop local tunnel, and retry remote-export?"; then
        did_cleanup=1
        tunnel_stop || warn "Local tunnel stop failed or no tunnel was found."
        remote_dst_close || warn "Remote NBD close failed or no export was found."
        continue
      fi
      die "Remote export failed because NBD port ${NBD_PORT} is already in use. Choose another per-run port with: ./vmigrate set-nbd-port auto"
    fi

    return "$rc"
  done

  die "Remote export failed after recovery attempts."
}

remote_dst_status(){
  load_config
  need ssh
  remote_context
  remote_ssh "cd '$(remote_dir)' && ./vmigrate-agent status"
}

remote_dst_close(){
  load_config
  need ssh
  remote_context
  remote_ssh "cd '$(remote_dir)' && ./vmigrate-agent close"
}

remote_port_is_free(){
  local port="$1" hit
  hit="$(remote_ssh "ss -lnt 2>/dev/null | grep -E '(^|[[:space:]])[^[:space:]]*:${port}[[:space:]]' || true")" || true
  [[ -z "$hit" ]]
}

pick_auto_nbd_port(){
  local base port i
  base=$((10000 + (TARGET_ID % 50000)))
  (( base < 1024 )) && base=10809
  (( base > 65000 )) && base=$((10809 + (TARGET_ID % 1000)))

  for i in $(seq 0 100); do
    port=$((base + i))
    (( port > 65535 )) && break
    if remote_port_is_free "$port"; then
      printf '%s\n' "$port"
      return 0
    fi
  done

  return 1
}

set_nbd_port(){
  local port="${1:-}" rdir old_port
  [[ -n "$port" ]] || die "Usage: ./vmigrate set-nbd-port PORT|auto"

  load_config
  need ssh

  old_port="$NBD_PORT"
  rdir="$(remote_dir)"

  if [[ "$port" == "auto" ]]; then
    info "Selecting free per-run NBD port based on TARGET_ID=$TARGET_ID"
    port="$(pick_auto_nbd_port)" || die "Could not find a free NBD port automatically"
  else
    case "$port" in *[!0-9]*|'') die "NBD port must be numeric or auto" ;; esac
    (( port >= 1024 && port <= 65535 )) || die "NBD port must be between 1024 and 65535"
  fi

  echo "Set per-run NBD port"
  echo "--------------------"
  remote_context
  echo
  warn "This changes only the active run config and its remote per-run vmigrate.env."
  warn "It does not enable parallel migration automatically."

  if [[ "$old_port" != "$port" ]]; then
    if ! remote_port_is_free "$port"; then
      die "Selected NBD port is already listening on destination: $port"
    fi
  fi

  write_key NBD_PORT "$port"
  NBD_PORT="$port"

  remote_ssh "cd '$rdir' && test -f vmigrate.env && awk -v v='$port' 'BEGIN{done=0} /^NBD_PORT=/{print \"NBD_PORT=\" v; done=1; next} {print} END{if(!done) print \"NBD_PORT=\" v}' vmigrate.env > vmigrate.env.tmp && mv vmigrate.env.tmp vmigrate.env && chmod 600 vmigrate.env" || die "Could not update remote vmigrate.env NBD_PORT"

  ok "NBD_PORT updated for active run: $port"
  echo
  remote_run_check
}

remote_run_check(){
  load_config
  need ssh

  local rdir out rt_id rt_disk rt_port rt_export mismatch=0
  rdir="$(remote_dir)"

  echo "Remote run check"
  echo "----------------"
  remote_context
  echo

  out="$(remote_ssh "cd '$rdir' && if [ -f vmigrate.env ]; then cat vmigrate.env; else echo '__MISSING_ENV__'; fi")" || die "Could not read remote vmigrate.env"

  if printf '%s\n' "$out" | grep -q '^__MISSING_ENV__$'; then
    die "Remote env missing: $rdir/vmigrate.env"
  fi

  rt_id="$(printf '%s\n' "$out" | awk -F= '$1=="TARGET_ID"{print substr($0,index($0,"=")+1); exit}')"
  rt_disk="$(printf '%s\n' "$out" | awk -F= '$1=="TARGET_DISK"{print substr($0,index($0,"=")+1); exit}')"
  rt_port="$(printf '%s\n' "$out" | awk -F= '$1=="NBD_PORT"{print substr($0,index($0,"=")+1); exit}')"
  rt_export="$(printf '%s\n' "$out" | awk -F= '$1=="NBD_EXPORT"{print substr($0,index($0,"=")+1); exit}')"

  echo "Compare local vs remote env"
  echo "---------------------------"
  printf 'TARGET_ID   local=%s remote=%s\n' "$TARGET_ID" "${rt_id:-}"
  printf 'TARGET_DISK local=%s remote=%s\n' "$TARGET_DISK" "${rt_disk:-}"
  printf 'NBD_PORT    local=%s remote=%s\n' "$NBD_PORT" "${rt_port:-}"
  printf 'NBD_EXPORT  local=%s remote=%s\n' "$NBD_EXPORT" "${rt_export:-}"

  [[ "$TARGET_ID" == "${rt_id:-}" ]] || mismatch=1
  [[ "$TARGET_DISK" == "${rt_disk:-}" ]] || mismatch=1
  [[ "$NBD_PORT" == "${rt_port:-}" ]] || mismatch=1
  [[ "$NBD_EXPORT" == "${rt_export:-}" ]] || mismatch=1

  if [[ "$mismatch" == "0" ]]; then
    ok "Remote run env matches local config"
  else
    die "Remote run env mismatch"
  fi
}

resume_check(){
  local mode="${1:-}"
  [[ -z "$mode" || "$mode" == "--run" ]] || die "Usage: ./vmigrate resume [--run]"

  load_config
  state_sync_identity

  local active_dir run_id remote_name verify method
  local remote_env="FAIL" remote_export="CLOSED" tunnel="DOWN" target_node="SKIP" bitmap="MISSING"
  local full final source_stopped next proc rdir out rt_id rt_disk rt_port rt_export mismatch=0

  active_dir="$(config_dir)"
  run_id="${active_dir##*/}"
  rdir="$(remote_dir)"
  remote_name="${rdir##*/}"
  method="$(effective_backup_method)"

  full="not completed"
  final="not completed"
  source_stopped="no"
  [[ "$(state_get FULL_COMPLETED)" == "1" ]] && full="completed"
  [[ "$(state_get FINAL_COMPLETED)" == "1" ]] && final="completed"
  [[ "$(state_get SOURCE_STOPPED)" == "1" ]] && source_stopped="yes"

  verify="NOT_RUN"
  [[ -f "$active_dir/summary.txt" ]] && verify="$(awk -F= '$1=="VERIFY"{print $2; exit}' "$active_dir/summary.txt")"
  [[ -n "$verify" ]] || verify="NOT_RUN"

  if out="$(remote_ssh "cd '$rdir' && if [ -f vmigrate.env ]; then cat vmigrate.env; else echo '__MISSING_ENV__'; fi" 2>/dev/null)"; then
    if ! printf '%s\n' "$out" | grep -q '^__MISSING_ENV__$'; then
      rt_id="$(printf '%s\n' "$out" | awk -F= '$1=="TARGET_ID"{print substr($0,index($0,"=")+1); exit}')"
      rt_disk="$(printf '%s\n' "$out" | awk -F= '$1=="TARGET_DISK"{print substr($0,index($0,"=")+1); exit}')"
      rt_port="$(printf '%s\n' "$out" | awk -F= '$1=="NBD_PORT"{print substr($0,index($0,"=")+1); exit}')"
      rt_export="$(printf '%s\n' "$out" | awk -F= '$1=="NBD_EXPORT"{print substr($0,index($0,"=")+1); exit}')"
      [[ "$TARGET_ID" == "${rt_id:-}" ]] || mismatch=1
      [[ "$TARGET_DISK" == "${rt_disk:-}" ]] || mismatch=1
      [[ "$NBD_PORT" == "${rt_port:-}" ]] || mismatch=1
      [[ "$NBD_EXPORT" == "${rt_export:-}" ]] || mismatch=1
      [[ "$mismatch" == "0" ]] && remote_env="OK" || remote_env="MISMATCH"
    fi
  fi

  proc="$(remote_ssh "ps -eo pid=,args= | grep '[q]emu-nbd' | grep -- ' -p ${NBD_PORT} ' || true" 2>/dev/null || true)"
  if [[ -n "$proc" ]]; then
    if printf '%s\n' "$proc" | grep -F -- " -x ${NBD_EXPORT} " >/dev/null && printf '%s\n' "$proc" | grep -F -- "$TARGET_DISK" >/dev/null; then
      remote_export="OK"
    else
      remote_export="BUSY_OTHER"
    fi
  fi

  if tunnel_health_ok >/dev/null 2>&1; then tunnel="OK"; fi

  if [[ "$method" == "blockdev-backup" ]]; then
    if target_node_exists >/dev/null 2>&1; then target_node="OK"; else target_node="MISSING"; fi
  fi

  if bitmap_exists >/dev/null 2>&1; then bitmap="OK"; fi

  next=""
  if [[ "$remote_env" != "OK" ]]; then
    next="./vmigrate remote-run-check"
  elif [[ "$remote_export" == "BUSY_OTHER" ]]; then
    next="./vmigrate set-nbd-port PORT"
  elif [[ "$remote_export" != "OK" ]]; then
    next="./vmigrate remote-export"
  elif [[ "$tunnel" != "OK" ]]; then
    next="./vmigrate tunnel"
  elif [[ "$target_node" == "MISSING" ]]; then
    next="./vmigrate attach-target"
  elif [[ "$bitmap" != "OK" ]]; then
    next="./vmigrate bitmap"
  elif [[ "$full" != "completed" ]]; then
    if [[ "$(state_get FULL_STARTED)" == "1" ]]; then
      next="./vmigrate wait-full"
    else
      next="./vmigrate full"
    fi
  elif [[ "$final" != "completed" ]]; then
    next="./vmigrate incremental"
  elif [[ "$source_stopped" != "yes" ]]; then
    next="./vmigrate stop-source"
  elif [[ "$verify" != "PASS" ]]; then
    next="./vmigrate verify"
  else
    next="Migration appears complete"
  fi

  cat <<EOF
Resume analysis
---------------

VM            : $VM_NAME
Run           : $run_id
Remote run    : $remote_name
Backup method : $method

Remote env    : $remote_env
Remote export : $remote_export
Tunnel        : $tunnel
Target node   : $target_node
Bitmap        : $bitmap

FULL          : $full
FINAL         : $final
SOURCE stopped: $source_stopped
VERIFY        : $verify

Recommended next step:
  $next
EOF

  if [[ "$mode" == "--run" ]]; then
    echo
    echo "Running recommended safe step..."
    case "$next" in
      "./vmigrate remote-run-check") remote_run_check ;;
      "./vmigrate remote-export") remote_export ;;
      "./vmigrate tunnel") start_tunnel ;;
      "./vmigrate attach-target") attach_target ;;
      "./vmigrate bitmap") create_bitmap ;;
      "./vmigrate full") full_sync ;;
      "./vmigrate wait-full") wait_full ;;
      "./vmigrate incremental") incremental_sync ;;
      "./vmigrate verify") sample_verify 64 ;;
      "./vmigrate set-nbd-port PORT")
        die "Cannot auto-run set-nbd-port without a concrete PORT. Run set-nbd-port auto or set-nbd-port PORT manually."
        ;;
      "./vmigrate stop-source"| "./vmigrate final")
        die "Refusing to auto-run high-risk step: $next. Run it manually after review."
        ;;
      "Migration appears complete")
        ok "Migration appears complete"
        ;;
      *)
        die "Unknown resume next step: $next"
        ;;
    esac
  fi
}

cleanup_remote_runs(){
