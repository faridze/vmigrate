help_cmd(){
  local topic="${1:-overview}"

  case "$topic" in
    ""|overview)
      cat <<EOF
vmigrate help
=============

vmigrate is run-based. Most commands operate on the active run.

Recommended path:
  ./vmigrate create VM_NAME TARGET_ID TARGET_HOST SSH_PORT root

Help topics:
  ./vmigrate help create      Guided create workflow
  ./vmigrate help manual      Manual step-by-step workflow
  ./vmigrate help batch       Sequential batch FULL workflow
  ./vmigrate help resume      Continue after interruption
  ./vmigrate help ports       Automatic/manual NBD port handling
  ./vmigrate help status      Status, reports, jobs, history
  ./vmigrate help cleanup     Safe cleanup and stale cleanup
  ./vmigrate help upgrade     Check and upgrade vmigrate from git

Common status commands:
  ./vmigrate active           Show active run
  ./vmigrate list             List all runs
  ./vmigrate history          Show latest run per VM
  ./vmigrate show             Show active run config
  ./vmigrate resume           Show next recommended step
  ./vmigrate report           Show migration report

Safety:
  - Use placeholders like TARGET_HOST in docs/examples.
  - Do not start the destination VM until final cutover is done, source is stopped, and NBD/tunnel are closed.
  - resume --run refuses high-risk steps such as final and stop-source.
EOF
      ;;

    create)
      cat <<EOF
Create guided migration
=======================

Use this for the normal production path.

Command:
  ./vmigrate create VM_NAME TARGET_ID TARGET_HOST SSH_PORT root

Example with placeholders:
  ./vmigrate create v1001 2001 TARGET_HOST 22 root

What create does:
  1. Creates a new local run directory.
  2. Makes it the active run.
  3. Creates a per-run remote workspace.
  4. Copies vmigrate-agent to the destination.
  5. Discovers source and destination disk info.
  6. Selects an automatic per-run NBD port.
  7. Opens destination NBD export.
  8. Starts/reuses SSH tunnel.
  9. Creates bitmap.
 10. Starts FULL sync and waits.
 11. Offers optional incremental sync.
 12. Runs final cutover only after confirmation.
 13. Asks before stopping source.
 14. Asks before cleanup.

Confirm words you may be asked to type:
  YES
  FULL
  CUTOVER
  STOP
  CLEAN

Important:
  STOP is only after final completed.
  CLEAN closes export/tunnel only. It does not delete disks or VMs.
EOF
      ;;

    manual)
      cat <<EOF
Manual migration workflow
=========================

Use this when you want to control each step yourself.

Prepare:
  ./vmigrate remote-prepare VM_NAME TARGET_ID TARGET_HOST SSH_PORT root
  ./vmigrate remote-run-check
  ./vmigrate doctor

Open destination export and tunnel:
  ./vmigrate remote-export
  ./vmigrate tunnel
  ./vmigrate tunnel-check

Prepare source block tracking:
  ./vmigrate bitmap
  ./vmigrate check-bitmap

Run FULL sync:
  ./vmigrate full
  ./vmigrate wait-full
  ./vmigrate report

Optional pre-cutover incremental:
  ./vmigrate incremental
  ./vmigrate wait-inc

Final cutover:
  ./vmigrate cutover-check
  ./vmigrate final

Post-cutover:
  ./vmigrate verify
  ./vmigrate stop-source

Cleanup:
  ./vmigrate remote-dst-close
  ./vmigrate tunnel-stop

High-risk steps:
  ./vmigrate final
  ./vmigrate stop-source

Review status before high-risk steps:
  ./vmigrate resume
  ./vmigrate report
EOF
      ;;

    batch)
      cat <<EOF
Batch FULL workflow
===================

Batch mode runs FULL syncs sequentially and continues after item failure.
It does not perform final cutover.

Batch file format:
  VM_NAME TARGET_ID TARGET_HOST [SSH_PORT] [SSH_USER]

Create example batch file:
  cat > batch.txt <<'EOF_BATCH'
v1001 2001 TARGET_HOST 22 root
v1002 2002 TARGET_HOST 22 root
EOF_BATCH

Run batch FULL:
  ./vmigrate batch-full batch.txt

Batch behavior:
  - creates one run per VM
  - prepares destination per run
  - uses automatic per-run NBD port
  - opens export/tunnel per item
  - runs FULL and waits
  - closes export/tunnel before next item
  - continues after failed item
  - writes batch summary under migrations/batches/

After batch:
  ./vmigrate list
  ./vmigrate history
  ./vmigrate history VM_NAME --all

Review one run:
  ./vmigrate use VM_NAME RUN_ID
  ./vmigrate resume
  ./vmigrate report

Cutover is manual per VM after review.
EOF
      ;;

    resume)
      cat <<EOF
Resume after interruption
=========================

Use this after SSH disconnect, tmux close, reboot, or when you forgot the next step.

Read-only analysis:
  ./vmigrate resume

Run the next safe step automatically:
  ./vmigrate resume --run

resume checks:
  - remote env consistency
  - remote NBD export
  - local SSH tunnel
  - target node
  - source bitmap
  - FULL state
  - FINAL state
  - source stopped state
  - verify state

Safe steps resume --run may execute:
  remote-run-check
  remote-export
  tunnel
  attach-target
  bitmap
  full
  wait-full
  incremental
  verify

High-risk steps are refused:
  ./vmigrate final
  ./vmigrate stop-source

For high-risk steps, review first:
  ./vmigrate resume
  ./vmigrate report
EOF
      ;;

    ports)
      cat <<EOF
NBD port management
===================

New runs select automatic per-run NBD ports by default.

Pick automatic free port for active run:
  ./vmigrate set-nbd-port auto

Set a fixed port:
  ./vmigrate set-nbd-port 10809

Verify local/remote env after port change:
  ./vmigrate remote-run-check

Disable automatic port selection for a new create:
  VMIGRATE_AUTO_NBD_PORT=0 ./vmigrate create VM_NAME TARGET_ID TARGET_HOST SSH_PORT root

If port is busy:
  ./vmigrate remote-dst-status
  ./vmigrate remote-dst-close
  ./vmigrate set-nbd-port auto
  ./vmigrate remote-run-check

Production note:
  Parallel migrations should still be tested carefully. Use separate NBD ports and watch destination I/O load.
EOF
      ;;

    status)
      cat <<EOF
Status, reports, and jobs
=========================

Show active run:
  ./vmigrate active

List runs:
  ./vmigrate list

Show latest history:
  ./vmigrate history

Show all history for one VM:
  ./vmigrate history VM_NAME --all

Show failed runs:
  ./vmigrate history --failed

Show current config:
  ./vmigrate show

Show report:
  ./vmigrate report

Watch block job progress:
  ./vmigrate watch

Show QEMU block jobs:
  ./vmigrate jobs

Dismiss concluded jobs:
  ./vmigrate jobs-dismiss-all

Cancel a running job:
  ./vmigrate job-cancel JOB_ID

Force-cancel a stuck job:
  ./vmigrate job-cancel-force JOB_ID

Common job IDs:
  full
  inc1
  final
EOF
      ;;

    cleanup)
      cat <<EOF
Cleanup and stale recovery
==========================

Normal cleanup for active run:
  ./vmigrate cleanup

Stop local tunnel:
  ./vmigrate tunnel-stop

Close destination NBD export:
  ./vmigrate remote-dst-close

Show destination NBD status:
  ./vmigrate remote-dst-status

Safe stale cleanup:
  ./vmigrate cleanup-stale

Force stale cleanup:
  ./vmigrate cleanup-stale --force

Show locks:
  ./vmigrate lock-status

Remove stale locks:
  ./vmigrate unlock-stale

List old remote run directories without deleting:
  ./vmigrate cleanup-remote-runs --dry-run

Recover stale tunnel/export:
  ./vmigrate tunnel-stop
  ./vmigrate remote-dst-close
  ./vmigrate remote-export
  ./vmigrate tunnel
  ./vmigrate tunnel-check

Safety:
  cleanup does not delete disks, LVs, VM definitions, or migrated data.
EOF
      ;;

    upgrade)
      cat <<EOF
Upgrade vmigrate
================

Read-only check:
  ./vmigrate upgrade-check

Upgrade from current git branch:
  ./vmigrate upgrade

Safety:
  - requires a git checkout
  - refuses dirty working tree
  - refuses detached HEAD
  - uses git pull --ff-only
  - validates vmigrate and vmigrate-agent syntax after upgrade
  - rolls back to the previous commit if syntax validation fails

Recommended:
  Run upgrade only when no migration is active.
EOF
      ;;

    *)
      die "Unknown help topic: $topic. Try: ./vmigrate help"
      ;;
  esac
}

ask(){ local var="$1" prompt="$2" def="${3:-}" val; read -r -p "$prompt${def:+ [$def]}: " val; printf -v "$var" '%s' "${val:-$def}"; }
confirm(){ local prompt="$1" ans; read -r -p "$prompt [yes/no]: " ans; [[ "$ans" == "yes" ]]; }
ask_exact(){
  local prompt="$1" expected="$2" ans
  read -r -p "$prompt " ans
  [[ "$ans" == "$expected" ]]
}
ask_yes_default(){
  local prompt="$1" ans
  while true; do
    read -r -p "$prompt [Y/n]: " ans
    case "$ans" in
      ""|Y|y) return 0 ;;
      N|n) return 1 ;;
      *) echo "Please answer Y or N." ;;
    esac
  done
}

sanitize_name(){ printf '%s' "$1" | tr -c 'A-Za-z0-9_.-' '-'; }
default_bitmap(){ printf 'vmigrate-bitmap-%s' "$(sanitize_name "$1")"; }
default_target_node(){ printf 'vmigrate-target-%s' "$(sanitize_name "$1")"; }

load_config(){
  [[ -f "$CONFIG_FILE" ]] || die "Config not found: $CONFIG_FILE. Run: ./vmigrate discover VM_NAME"
  # shellcheck disable=SC1090
  source "$CONFIG_FILE"
  : "${VM_NAME:?}"; : "${TARGET_HOST:?}"; : "${TARGET_SSH_USER:=root}"; : "${TARGET_SSH_PORT:=22}"; : "${TARGET_ID:?}"; : "${TARGET_DISK:?}"
  SRC_DISK="${SRC_DISK:-}"
  QEMU_DEVICE="${QEMU_DEVICE:-}"
  QEMU_NODE="${QEMU_NODE:-}"
  BITMAP="${BITMAP:-$(default_bitmap "$VM_NAME")}"
  TARGET_NODE="${TARGET_NODE:-$(default_target_node "$VM_NAME")}"
  NBD_PORT="${NBD_PORT:-10809}"
  NBD_EXPORT="${NBD_EXPORT:-vm-${TARGET_ID}}"
  TUNNEL_MODE="${TUNNEL_MODE:-autossh}"
  AUTOSSH_MONITOR_PORT="${AUTOSSH_MONITOR_PORT:-20000}"
  BACKUP_METHOD="${BACKUP_METHOD:-drive-backup}"
  FULL_METHOD="${FULL_METHOD:-auto}"
  QMP_TIMEOUT="${QMP_TIMEOUT:-20}"
  CHECK_TIMEOUT="${CHECK_TIMEOUT:-8}"
  NBD_IO_TIMEOUT="${NBD_IO_TIMEOUT:-20}"
}

get_conf(){ local key="$1"; [[ -f "$CONFIG_FILE" ]] || return 0; awk -F= -v k="$key" '$1==k {print substr($0, index($0,"=")+1); exit}' "$CONFIG_FILE"; }
write_key(){
  local key="$1" val="$2" tmp
  tmp="$(mktemp)"
  [[ -f "$CONFIG_FILE" ]] && grep -v -E "^${key}=" "$CONFIG_FILE" > "$tmp" || true
  printf '%s=%s\n' "$key" "$val" >> "$tmp"
  mv "$tmp" "$CONFIG_FILE"
}

now_ts(){ date '+%Y-%m-%d %H:%M:%S %z'; }
config_dir(){ case "$CONFIG_FILE" in */*) printf '%s' "${CONFIG_FILE%/*}" ;; *) printf '.' ;; esac; }

IN_CREATE_WORKFLOW=0
IN_BATCH_WORKFLOW=0
LOG_STARTED=0
LOG_FILE=""
RUN_ID=""
RUN_DIR=""

in_create_workflow(){ [[ "${IN_CREATE_WORKFLOW:-0}" == "1" ]]; }

next_hint(){
  in_create_workflow && return 0
  printf '%s\n' "$*"
}

start_log(){
  local vm="${1:-unknown}" runs_base safe_vm was_tty=0
  (( LOG_STARTED )) && return 0

  [[ -t 1 ]] && was_tty=1

  safe_vm="$(sanitize_name "$vm")"
  RUN_ID="${RUN_ID:-$(date '+%Y%m%d-%H%M%S')}"
  runs_base="${VMIGRATE_RUNS_DIR:-${SCRIPT_DIR}/migrations}"
  RUN_DIR="${runs_base}/${safe_vm}/${RUN_ID}"
  mkdir -p "$RUN_DIR"

  LOG_FILE="${RUN_DIR}/run.log"
  LOG_STARTED=1

  if [[ "${VMIGRATE_LOG:-1}" == "0" ]]; then
    ok "Run directory: $RUN_DIR"
    return 0
  fi

  exec > >(tee -a "$LOG_FILE") 2>&1
  [[ "$was_tty" == "1" ]] && VMIGRATE_PROGRESS_COMPACT=1
  ok "Log file: $LOG_FILE"
  ok "Run directory: $RUN_DIR"
}

state_file(){
  local vm
  vm="${VM_NAME:-$(get_conf VM_NAME)}"
  [[ -n "$vm" ]] || vm="unknown"
  state_file_for_vm "$vm"
}
state_file_for_vm(){ printf '%s/.vmigrate-state-%s' "$(config_dir)" "$(sanitize_name "$1")"; }
state_get(){ local key="$1" file; file="$(state_file)"; [[ -f "$file" ]] || return 0; awk -F= -v k="$key" '$1==k {print substr($0, index($0,"=")+1); exit}' "$file"; }
state_get_from_file(){ local file="$1" key="$2"; [[ -f "$file" ]] || return 0; awk -F= -v k="$key" '$1==k {print substr($0, index($0,"=")+1); exit}' "$file"; }
state_write_file(){
  local file="$1" key="$2" val="$3" tmp
  tmp="$(mktemp)"
  [[ -f "$file" ]] && grep -v -E "^${key}=" "$file" > "$tmp" || true
  printf '%s=%s\n' "$key" "$val" >> "$tmp"
  mv "$tmp" "$file"
  chmod 600 "$file" 2>/dev/null || true
}
state_write(){
  local key="$1" val="$2" file
  file="$(state_file)"
  state_write_file "$file" "$key" "$val"
}
state_sync_identity(){
  state_write VM_NAME "${VM_NAME:-}"
  state_write SRC_DISK "${SRC_DISK:-}"
  state_write TARGET_DISK "${TARGET_DISK:-}"
  [[ -n "$(state_get FULL_STARTED)" ]] || state_write FULL_STARTED 0
  [[ -n "$(state_get FULL_STARTED_AT)" ]] || state_write FULL_STARTED_AT ""
  [[ -n "$(state_get FULL_JOB_ID)" ]] || state_write FULL_JOB_ID ""
  [[ -n "$(state_get FULL_COMPLETED)" ]] || state_write FULL_COMPLETED 0
  [[ -n "$(state_get FULL_COMPLETED_AT)" ]] || state_write FULL_COMPLETED_AT ""
  [[ -n "$(state_get FINAL_COMPLETED)" ]] || state_write FINAL_COMPLETED 0
  [[ -n "$(state_get FINAL_COMPLETED_AT)" ]] || state_write FINAL_COMPLETED_AT ""
  [[ -n "$(state_get SOURCE_STOPPED)" ]] || state_write SOURCE_STOPPED 0
  [[ -n "$(state_get SOURCE_STOPPED_AT)" ]] || state_write SOURCE_STOPPED_AT ""
}
activate_run_dir(){
  local dir="$1"
  [[ -n "$dir" ]] || die "Run directory is empty"
  [[ -d "$dir" ]] || die "Run directory not found: $dir"

  rm -f "$ACTIVE_FILE"
  if ln -s "$dir" "$ACTIVE_FILE" 2>/dev/null; then
    :
  else
    printf '%s\n' "$dir" > "$ACTIVE_FILE"
  fi

  ok "Active run: $dir"
  ok "Active config: $dir/config"
}

runs_base_dir(){
  printf '%s\n' "${VMIGRATE_RUNS_DIR:-${SCRIPT_DIR}/migrations}"
}

run_config_value(){
  local cfg="$1" key="$2"
  [[ -f "$cfg" ]] || return 0
  awk -F= -v k="$key" '$1==k {print substr($0, index($0,"=")+1); exit}' "$cfg"
}

run_status_for_dir(){
  local dir="$1" cfg vm safe_vm state full_started full_completed final_completed source_stopped
  cfg="$dir/config"
  vm="$(run_config_value "$cfg" VM_NAME)"
  [[ -n "$vm" ]] || vm="${dir%/*}"
  vm="${vm##*/}"
  safe_vm="$(sanitize_name "$vm")"
  state="$dir/.vmigrate-state-$safe_vm"

  full_started="$(state_get_from_file "$state" FULL_STARTED)"
  full_completed="$(state_get_from_file "$state" FULL_COMPLETED)"
  final_completed="$(state_get_from_file "$state" FINAL_COMPLETED)"
  source_stopped="$(state_get_from_file "$state" SOURCE_STOPPED)"

  if [[ "$source_stopped" == "1" ]]; then
    printf 'source-stopped'
  elif [[ "$final_completed" == "1" ]]; then
    printf 'final'
  elif [[ "$full_completed" == "1" ]]; then
    printf 'after-full'
  elif [[ "$full_started" == "1" ]]; then
    printf 'full-started'
  elif [[ -f "$cfg" ]]; then
    printf 'prepared'
  else
    printf 'created'
  fi
}

runs_list(){
  local base active dir cfg vm run status full final mark found=0
  base="$(runs_base_dir)"
  active="$(active_run_dir 2>/dev/null || true)"

  printf '%-6s %-18s %-20s %-15s %-5s %-5s %-8s %-24s %s\n' "ACTIVE" "VM" "RUN_ID" "STATUS" "FULL" "FINAL" "VERIFY" "REMOTE" "REL_DIR"

  shopt -s nullglob
  for dir in "$base"/*/*; do
    [[ -d "$dir" ]] || continue
    case "$dir" in "$base"/batches/*) continue ;; esac
    found=1
    cfg="$dir/config"
    vm="${dir%/*}"
    vm="${vm##*/}"
    run="${dir##*/}"

    if [[ -f "$cfg" ]]; then
      local cfg_vm
      cfg_vm="$(run_config_value "$cfg" VM_NAME)"
      [[ -n "$cfg_vm" ]] && vm="$cfg_vm"
    fi

    status="$(run_status_for_dir "$dir")"
    full="no"
    final="no"

    local state safe_vm
    safe_vm="$(sanitize_name "$vm")"
    state="$dir/.vmigrate-state-$safe_vm"
    [[ "$(state_get_from_file "$state" FULL_COMPLETED)" == "1" ]] && full="yes"
    [[ "$(state_get_from_file "$state" FINAL_COMPLETED)" == "1" ]] && final="yes"

    mark=""
    [[ -n "$active" && "$dir" == "$active" ]] && mark="*"

    rel_dir="migrations/${dir#"$base"/}"
    verify="unset"
    [[ -f "$dir/summary.txt" ]] && verify="$(awk -F= '$1=="VERIFY"{print $2; exit}' "$dir/summary.txt")"
    [[ -n "$verify" ]] || verify="unset"
    remote="$(run_config_value "$cfg" REMOTE_RUN_DIR)"
    remote="${remote##*/}"
    [[ -n "$remote" ]] || remote="-"
    printf '%-6s %-18s %-20s %-15s %-5s %-5s %-8s %-24s %s\n' "$mark" "$vm" "$run" "$status" "$full" "$final" "$verify" "$remote" "$rel_dir"
  done
  shopt -u nullglob

  if (( ! found )); then
    warn "No migration runs found in: $base"
  fi
}

run_use(){
  local first="${1:-}" second="${2:-}" dir
  [[ -n "$first" ]] || die "Usage: ./vmigrate use VM_NAME RUN_ID  OR  ./vmigrate use RUN_DIR"

  if [[ -n "$second" ]]; then
    dir="$(runs_base_dir)/$(sanitize_name "$first")/$second"
  else
    dir="$first"
    case "$dir" in
      /*) ;;
      *) [[ -d "$SCRIPT_DIR/$dir" ]] && dir="$SCRIPT_DIR/$dir" ;;
    esac
  fi

  [[ -d "$dir" ]] || die "Run directory not found: $dir"
  [[ -f "$dir/config" ]] || die "Run config not found: $dir/config"

  activate_run_dir "$dir"
}

run_active(){
  local dir
  if ! dir="$(active_run_dir 2>/dev/null)"; then
    warn "No active run is set. Fallback config: $CONFIG_FILE"
    return 1
  fi
  echo "Active run    : $dir"
  echo "Active config : $dir/config"
  if [[ -f "$dir/config" ]]; then
    echo "VM name       : $(run_config_value "$dir/config" VM_NAME)"
    echo "Target ID     : $(run_config_value "$dir/config" TARGET_ID)"
    echo "Target host   : $(run_config_value "$dir/config" TARGET_HOST)"
  else
    warn "Active config does not exist: $dir/config"
  fi
}

run_clear_active(){
  rm -f "$ACTIVE_FILE"
  ok "Active run cleared. Fallback config: $DEFAULT_CONFIG_FILE"
}

run_env(){
  local first="${1:-}" second="${2:-}" dir

  [[ -n "$first" ]] || die "Usage: ./vmigrate env VM_NAME RUN_ID  OR  ./vmigrate env RUN_DIR"

  if [[ -n "$second" ]]; then
    dir="$(runs_base_dir)/$(sanitize_name "$first")/$second"
  else
    dir="$first"
    case "$dir" in
      /*) ;;
      *) [[ -d "$SCRIPT_DIR/$dir" ]] && dir="$SCRIPT_DIR/$dir" ;;
    esac
  fi

  [[ -d "$dir" ]] || die "Run directory not found: $dir"
  [[ -f "$dir/config" ]] || die "Run config not found: $dir/config"

  printf "export VMIGRATE_CONFIG='%s/config'\n" "$dir"
}

version_cmd(){
  echo "vmigrate $VERSION"
  echo

  if command -v git >/dev/null 2>&1; then
    local branch commit dirty
    branch="$(cd "$SCRIPT_DIR" 2>/dev/null && git rev-parse --abbrev-ref HEAD 2>/dev/null || echo unknown)"
    commit="$(cd "$SCRIPT_DIR" 2>/dev/null && git rev-parse --short HEAD 2>/dev/null || echo unknown)"
    if (cd "$SCRIPT_DIR" 2>/dev/null && git diff --quiet --ignore-submodules -- 2>/dev/null && git diff --cached --quiet --ignore-submodules -- 2>/dev/null); then
      dirty="no"
    else
      dirty="yes"
    fi

    cat <<EOF
Git:
  Branch : $branch
  Commit : $commit
  Dirty  : $dirty
EOF
  else
    echo "Git information unavailable"
  fi

  cat <<EOF

Paths:
  Base   : $SCRIPT_DIR
  Config : $CONFIG_FILE
EOF
}


state_is_full_completed(){ [[ "$(state_get FULL_COMPLETED)" == "1" ]]; }
state_is_final_completed(){ [[ "$(state_get FINAL_COMPLETED)" == "1" ]]; }
require_full_completed(){
  state_is_full_completed && return 0
  die "Full sync is not marked as completed. Refusing incremental/final. Run wait-full or mark-full only after confirming full completed successfully."
}
require_final_completed(){
  state_is_final_completed && return 0
  die "FINAL_COMPLETED=1 is not present in $(state_file). Refusing to stop/destroy the source VM."
}
mark_full_completed(){
  load_config
  state_sync_identity
  state_write FULL_COMPLETED 1
  state_write FULL_COMPLETED_AT "$(now_ts)"
}

