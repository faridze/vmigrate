qmp(){ local json="$1"; timeout "${QMP_TIMEOUT:-20}" virsh qemu-monitor-command "$VM_NAME" --pretty "$json"; }

parse_info_block(){
  awk '
    BEGIN {
      OFS=sprintf("%c", 9)
    }

    function emit() {
      if (device != "" && disk != "") {
        if (node == "")
          node=device
        print device, node, disk
      }
    }

    # Older/common HMP format:
    #   virtio0 (#block123): /path/to/disk (raw)
    /^[^[:space:]:]+[[:space:]]+\(#block[0-9]+\):/ {
      emit()
      device=$1
      node=$2
      gsub(/[():]/, "", node)
      disk=$0
      sub(/^[^:]+:[[:space:]]*/, "", disk)
      sub(/[[:space:]]+\([^)]+\).*$/, "", disk)
      emit()
      device=""; node=""; disk=""
      next
    }

    # Minimal libvirt/QEMU HMP format:
    #   libvirt-1-format: /dev/volgroup/kvm2644_img (raw)
    #   drive-virtio-disk0: /path/to/disk (qcow2)
    /^[^[:space:]][^:]*:[[:space:]]+/ {
      emit()
      device=$0
      sub(/:.*/, "", device)
      node=device
      disk=$0
      sub(/^[^:]+:[[:space:]]*/, "", disk)
      sub(/[[:space:]]+\([^)]+\).*$/, "", disk)
      next
    }

    /^[[:space:]]*node-name:[[:space:]]*/ {
      node=$0
      sub(/^[[:space:]]*node-name:[[:space:]]*/, "", node)
      next
    }

    /^[[:space:]]*file:[[:space:]]*/ {
      if (disk == "") {
        disk=$0
        sub(/^[[:space:]]*file:[[:space:]]*/, "", disk)
      }
      next
    }

    /^[[:space:]]*Attached to:[[:space:]]*/ {
      emit()
      device=""; node=""; disk=""
      next
    }

    END {
      emit()
    }
  ' | awk 'NF && !seen[$0]++'
}


