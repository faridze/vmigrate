    elif printf '%s\n' "$out" | grep -q '"error"'; then
      printf '%s\n' "$out"
    else
      echo "none"
    fi
  else
    warn "QMP query timed out"
  fi
}

cutover_check(){
  load_config
  local failed=0 state method
  method="$(effective_backup_method)"
  check_ok(){ printf 'OK   %s\n' "$1"; }
  check_fail(){ printf 'FAIL %s\n' "$1"; failed=1; }

  if command -v virsh >/dev/null 2>&1 && virsh list --all | awk '{print $2}' | grep -qx "$VM_NAME"; then check_ok "VM exists in virsh"; else check_fail "VM exists in virsh"; fi

  state="$(virsh domstate "$VM_NAME" 2>/dev/null | tr '[:upper:]' '[:lower:]' | awk '{print $1}' || true)"
  case "$state" in running|paused|pmsuspended) check_ok "VM is running or paused ($state)" ;; *) check_fail "VM is running or paused (${state:-unknown})" ;; esac

  if block_jobs_query_ok_empty >/dev/null; then check_ok "No active block job"; else check_fail "No active block job"; fi
  if [[ "$method" == "blockdev-backup" ]]; then
    if target_node_exists; then check_ok "Target node exists"; else check_fail "Target node exists"; fi
  else
    check_ok "Target node not required for drive-backup"
  fi
  if bitmap_exists; then check_ok "Bitmap exists"; else check_fail "Bitmap exists"; fi
  if command -v ss >/dev/null 2>&1 && ss -lntp | grep "127.0.0.1:${NBD_PORT}" >/dev/null; then check_ok "Local tunnel listener 127.0.0.1:${NBD_PORT}"; else check_fail "Local tunnel listener 127.0.0.1:${NBD_PORT}"; fi
  if tunnel_health_ok >/dev/null 2>&1; then check_ok "NBD export reachable"; else check_fail "NBD export reachable"; fi
  if state_is_full_completed; then check_ok "FULL_COMPLETED=1"; else check_fail "FULL_COMPLETED=1"; fi

  return "$failed"
}

disk_size_bytes(){
  local path="$1"
  if [[ -b "$path" ]]; then
    blockdev --getsize64 "$path"
  elif [[ -f "$path" ]]; then
    stat -c '%s' "$path"
  else
    return 1
  fi
}

random_u64(){
  od -An -N8 -tu8 /dev/urandom 2>/dev/null | awk '{print $1}'
}

verify_hash_local(){
  local disk="$1" skip_mb="$2" chunk_mb="$3"
  set +e
  local h rc
  h="$(dd if="$disk" bs=1M skip="$skip_mb" count="$chunk_mb" iflag=fullblock status=none 2>/tmp/vmigrate-verify-local.err | md5sum | awk '{print $1}')"
  rc=$?
  set -e
  [[ "$rc" -eq 0 && -n "$h" ]] || return 1
  printf '%s\n' "$h"
}

verify_hash_remote(){
  local disk="$1" skip_mb="$2" chunk_mb="$3" cmd h rc
  cmd="dd if='$disk' bs=1M skip=$skip_mb count=$chunk_mb iflag=fullblock status=none 2>/tmp/vmigrate-verify-remote.err | md5sum | awk '{print \$1}'"
  set +e
  h="$(remote_ssh "$cmd" | tail -n1)"
  rc=$?
  set -e
  [[ "$rc" -eq 0 && -n "$h" ]] || return 1
  printf '%s\n' "$h"
}

sample_verify(){
  load_config
  need dd
  need md5sum
  need ssh

  local samples="${1:-64}" chunk_mb="${VMIGRATE_VERIFY_CHUNK_MB:-4}" chunk_bytes
  local src_size target_size usable_size max_start_mb i rnd skip_mb src_hash target_hash
  local failed=0 compared_bytes elapsed start_ts end_ts target_cmd

  [[ "$samples" =~ ^[0-9]+$ && "$samples" -gt 0 ]] || die "Samples must be a positive number"
  [[ "$chunk_mb" =~ ^[0-9]+$ && "$chunk_mb" -gt 0 ]] || die "Chunk size must be a positive number"

  [[ -n "${SRC_DISK:-}" ]] || die "SRC_DISK is empty. Run discover first."
  [[ -e "$SRC_DISK" ]] || die "Source disk not found: $SRC_DISK"
  [[ -n "${TARGET_DISK:-}" ]] || die "TARGET_DISK is empty. Apply handoff/remote-prepare first."

  if [[ -z "${RUN_DIR:-}" && "${CONFIG_FILE##*/}" == "config" ]]; then
    RUN_DIR="$(config_dir)"
  fi

  chunk_bytes=$(( chunk_mb * 1024 * 1024 ))
  src_size="$(disk_size_bytes "$SRC_DISK")" || die "Could not read source disk size: $SRC_DISK"

  target_size="$(remote_ssh "blockdev --getsize64 '$TARGET_DISK' 2>/dev/null || stat -c '%s' '$TARGET_DISK' 2>/dev/null" | tail -n1)" || die "Could not read target disk size: $TARGET_DISK"
  [[ "$target_size" =~ ^[0-9]+$ ]] || die "Invalid target disk size returned: $target_size"

  usable_size="$src_size"
  if [[ "$target_size" -lt "$usable_size" ]]; then
    usable_size="$target_size"
    warn "Target disk is smaller than source; verifying common size only."
  fi

  [[ "$usable_size" -gt "$chunk_bytes" ]] || die "Disk is smaller than verify chunk size"

  max_start_mb=$(( (usable_size - chunk_bytes) / 1024 / 1024 ))
  [[ "$max_start_mb" -lt 0 ]] && max_start_mb=0
  compared_bytes=$(( samples * chunk_bytes ))

  cat <<EOF
Sample verify
-------------
Source     : $SRC_DISK
Target     : ${TARGET_SSH_USER}@${TARGET_HOST}:${TARGET_DISK}
Samples    : $samples
Chunk size : ${chunk_mb} MiB
Total read : $(format_bytes "$compared_bytes")
EOF

  start_ts="$(date +%s)"
  summary_set VERIFY "RUNNING"
  summary_set VERIFY_AT "$(now_ts)"
  summary_set VERIFY_SAMPLES "$samples"
  summary_set VERIFY_CHUNK_MB "$chunk_mb"
  summary_set VERIFY_COMPARED_BYTES "$compared_bytes"

  for ((i=1; i<=samples; i++)); do
    rnd=$(( (RANDOM << 15) | RANDOM ))
    [[ "$rnd" -lt 0 ]] && rnd=$(( -rnd ))
    skip_mb=$(( rnd % (max_start_mb + 1) ))

    if ! src_hash="$(verify_hash_local "$SRC_DISK" "$skip_mb" "$chunk_mb")"; then
      echo
      warn "Could not read source sample $i/$samples at offset ${skip_mb}MiB"
      [[ -s /tmp/vmigrate-verify-local.err ]] && cat /tmp/vmigrate-verify-local.err
      failed=1
      break
    fi

    if ! target_hash="$(verify_hash_remote "$TARGET_DISK" "$skip_mb" "$chunk_mb")"; then
      echo
      warn "Could not read target sample $i/$samples at offset ${skip_mb}MiB"
      warn "Check SSH access and target disk path."
      failed=1
      break
    fi

    if [[ -z "$src_hash" || -z "$target_hash" || "$src_hash" != "$target_hash" ]]; then
      echo
      warn "Verify mismatch at sample $i/$samples"
      echo "Offset MiB : $skip_mb"
      echo "Source MD5 : ${src_hash:-empty}"
      echo "Target MD5 : ${target_hash:-empty}"
      failed=1
      summary_set VERIFY "FAIL"
      summary_set VERIFY_OFFSET_MIB "$skip_mb"
      summary_set VERIFY_LAST_OFFSET_MIB "$skip_mb"
      summary_set VERIFY_FAILED_SAMPLE "$i"
      summary_set VERIFY_SOURCE_MD5 "${src_hash:-empty}"
      summary_set VERIFY_TARGET_MD5 "${target_hash:-empty}"
      summary_set VERIFY_SAMPLES "$samples"
      summary_set VERIFY_CHUNK_MB "$chunk_mb"
      break
    fi

    summary_set VERIFY_LAST_OFFSET_MIB "$skip_mb"
    printf '\r[%d/%d] verified offset=%sMiB' "$i" "$samples" "$skip_mb"
  done

  echo
  end_ts="$(date +%s)"
  elapsed=$(( end_ts - start_ts ))

  summary_set VERIFY_SAMPLES "$samples"
  summary_set VERIFY_CHUNK_MB "$chunk_mb"
  summary_set VERIFY_COMPARED_BYTES "$compared_bytes"
  summary_set VERIFY_ELAPSED_SECONDS "$elapsed"
  summary_set VERIFY_AT "$(now_ts)"

  if [[ "$failed" -eq 0 ]]; then
    summary_set VERIFY "PASS"
    ok "Sample verify PASSED"
    echo "Compared : $(format_bytes "$compared_bytes")"
    echo "Elapsed  : $(format_duration "$elapsed")"
    echo "Summary  : $(summary_file)"
    return 0
  fi

  warn "Sample verify FAILED"
  echo "Compared before fail: up to $(format_bytes "$(( i * chunk_bytes ))")"
  echo "Elapsed             : $(format_duration "$elapsed")"
  echo "Summary             : $(summary_file)"
  return 1
}

prompt_sample_verify(){
  [[ "${IN_BATCH_WORKFLOW:-0}" == "1" ]] && return 0

  if ask_yes_default "Run sample verify now?"; then
    sample_verify
  else
    summary_set VERIFY "SKIPPED"
    warn "Sample verify skipped"
  fi
}

watch_jobs(){
  load_config
  local out job status parsed_status offset len progress

  while true; do
    clear || true

    echo "vmigrate watch"
    echo "------------"
    echo "VM            : $VM_NAME"
    echo "Backup method : $(effective_backup_method)"
    echo "State         : $(virsh domstate "$VM_NAME" 2>/dev/null || echo unknown)"
    echo

    if ! out="$(block_jobs_json 2>/dev/null)"; then
      warn "QMP query timed out"
      echo
      echo "Retrying every 2 seconds..."
      sleep 2
      continue
    fi

    if printf '%s\n' "$out" | grep -q '"error"'; then
      warn "QMP returned an error"
      printf '%s\n' "$out"
      sleep 2
      continue
    fi

    if ! printf '%s\n' "$out" | grep -q '"type"'; then
      echo "No active block job."
      echo
      echo "Tip: use wait-full or wait-inc after submitting a job."
      sleep 2
      continue
    fi

    job="$(printf '%s\n' "$out" | awk -F'"' '/"device"/ {print $4; exit}')"
    status="$(printf '%s\n' "$out" | awk -F'"' '/"status"/ {print $4; exit}')"
    IFS=$'\t' read -r offset len parsed_status <<< "$(printf '%s\n' "$out" | progress_from_jobs_json)"
    [[ -n "$parsed_status" ]] && status="$parsed_status"

    echo "Job           : ${job:-unknown}"
    progress_line "$offset" "$len" "${status:-running}"
    echo

    if printf '%s\n' "$out" | grep -q '"error"'; then
      echo
      printf '%s\n' "$out" | grep '"error"' || true
    fi

    if [[ "$status" == "concluded" ]]; then
      echo
      echo "Job concluded."
      echo "Run: ./vmigrate jobs-dismiss-all"
      echo
      echo "Note: watch is read-only and will not dismiss jobs."
    fi

    sleep 2
  done
}


status(){
  load_config
  state_sync_identity

  local active_dir run_id vm_state full final verify tunnels lock lock_state out jobs_state

  active_dir="$(config_dir)"
  run_id="${active_dir##*/}"

  full="no"
  final="no"
  [[ "$(state_get FULL_COMPLETED)" == "1" ]] && full="yes"
  [[ "$(state_get FINAL_COMPLETED)" == "1" ]] && final="yes"

  verify="unset"
  [[ -f "$active_dir/summary.txt" ]] && verify="$(awk -F= '$1=="VERIFY"{print $2; exit}' "$active_dir/summary.txt")"
  [[ -n "$verify" ]] || verify="unset"

  vm_state="unknown"
  if command -v virsh >/dev/null 2>&1; then
    vm_state="$(virsh domstate "$VM_NAME" 2>/dev/null || echo unknown)"
  fi

  tunnels="$(migration_active_tunnels 2>/dev/null || true)"
  if [[ -n "$tunnels" ]]; then
    tunnels="$(printf '%s\n' "$tunnels" | awk '{print "running pid=" $1}' | head -n1)"
  else
    tunnels="stopped"
  fi

  lock_state="unlocked"
  lock="$(lock_path_for_vm "$VM_NAME" 2>/dev/null || true)"
  if [[ -n "$lock" && -d "$lock" ]]; then
    local pid
    pid="$(awk -F= '$1=="PID"{print $2; exit}' "$lock/info" 2>/dev/null || true)"
    if [[ -n "$pid" ]] && kill -0 "$pid" 2>/dev/null; then
      lock_state="locked pid=$pid"
    else
      lock_state="stale"
    fi
  fi

  jobs_state="unknown"
  if out="$(block_jobs_json 2>/dev/null)"; then
    if printf '%s\n' "$out" | grep -q '"type"'; then
      jobs_state="$(printf '%s\n' "$out" | block_jobs_summary | tr '\n' '; ' | sed 's/[; ]*$//')"
    elif printf '%s\n' "$out" | grep -q '"error"'; then
      jobs_state="QMP error"
    else
      jobs_state="none"
    fi
  else
    jobs_state="QMP timeout"
  fi

  cat <<EOF
Runtime Status
--------------

VM            : $VM_NAME
Run           : $run_id
VM state      : $vm_state

FULL          : $full
FINAL         : $final
VERIFY        : $verify

Target        : ${TARGET_SSH_USER}@${TARGET_HOST}:${TARGET_SSH_PORT}
Target ID     : $TARGET_ID
Target disk   : $TARGET_DISK
NBD           : 127.0.0.1:${NBD_PORT} (${NBD_EXPORT})

Tunnel        : $tunnels
Block jobs    : $jobs_state
Lock          : $lock_state

Config        : $CONFIG_FILE
Run dir       : $active_dir
EOF
}

final_cutover_run(){
  load_config
  cutover_check || die "Cutover check failed. Refusing to suspend source VM."
  virsh suspend "$VM_NAME" || die "virsh suspend failed"
  wait_vm_paused
  backup_job incremental final
  wait_jobs_empty
  state_sync_identity
  state_write FINAL_COMPLETED 1
  state_write FINAL_COMPLETED_AT "$(now_ts)"
  ok "Final incremental completed"
  prompt_sample_verify
}

final_cutover(){
  load_config
  require_full_completed
  warn "Before final cutover, lock customer/Virtualizor panel controls."
  confirm "Suspend source VM and run FINAL incremental now?" || die "Aborted"
  final_cutover_run
}

cleanup(){
  load_config
  pkill -f "${NBD_PORT}:127.0.0.1:${NBD_PORT}.*${TARGET_HOST}" >/dev/null 2>&1 || true
  if bitmap_exists; then
    qmp '{"execute":"block-dirty-bitmap-remove","arguments":{"node":"'"$QEMU_NODE"'","name":"'"$BITMAP"'"}}' || true
  fi
  ok "Source cleanup attempted"
}

stop_source_run(){
  load_config
  state_sync_identity
  require_final_completed
  if ! block_jobs_empty; then
    block_jobs_json
    die "Refusing to stop source VM while a block job is still present"
  fi
  virsh destroy "$VM_NAME"
  state_sync_identity
  state_write SOURCE_STOPPED 1
  state_write SOURCE_STOPPED_AT "$(now_ts)"
  ok "Source VM stopped and state updated"
}

stop_source(){
  load_config
  warn "This stops the source VM. Use only after final incremental completed."
  confirm "Destroy/stop source VM $VM_NAME now?" || die "Aborted"
  stop_source_run
}


migration_active_tunnels(){
  local nbd_port old_host
  nbd_port="$(get_conf NBD_PORT)"
  nbd_port="${nbd_port:-10809}"
  old_host="$(get_conf TARGET_HOST)"
  command -v pgrep >/dev/null 2>&1 || return 1
  pgrep -af '(^|/)(autossh|ssh)( |$)' 2>/dev/null | awk -v fwd="${nbd_port}:127.0.0.1:${nbd_port}" -v host="$old_host" '
    index($0, fwd) && (host == "" || index($0, host)) {print}
  '
}

migration_block_jobs_summary(){
  local old_vm qmp_timeout out
  old_vm="$(get_conf VM_NAME)"
  [[ -n "$old_vm" ]] || return 1
  command -v virsh >/dev/null 2>&1 || return 1
  command -v timeout >/dev/null 2>&1 || return 1
  qmp_timeout="$(get_conf QMP_TIMEOUT)"
  qmp_timeout="${qmp_timeout:-20}"
  if out="$(timeout "$qmp_timeout" virsh qemu-monitor-command "$old_vm" --pretty '{"execute":"query-block-jobs"}' 2>/dev/null)"; then
    if printf '%s\n' "$out" | grep -q '"type"'; then
      echo "VM $old_vm:"
      printf '%s\n' "$out" | block_jobs_summary
      return 0
    fi
  fi
  return 1
}

state_file_has_progress(){
  local file="$1" key val
  for key in FULL_STARTED FULL_COMPLETED FINAL_COMPLETED SOURCE_STOPPED; do
    val="$(state_get_from_file "$file" "$key")"
    [[ "$val" == "1" ]] && return 0
  done
  return 1
}

state_file_progress_summary(){
  local file="$1" key val
  state_file_has_progress "$file" || return 1
  printf '%s\n' "$file"
  for key in FULL_STARTED FULL_COMPLETED FINAL_COMPLETED SOURCE_STOPPED; do
    val="$(state_get_from_file "$file" "$key")"
    printf '  %s=%s\n' "$key" "${val:-unset}"
  done
}

state_reset_migration_values_for_vm(){
  local vm="$1" file
  file="$(state_file_for_vm "$vm")"
  state_write_file "$file" VM_NAME "$vm"
  state_write_file "$file" FULL_STARTED 0
  state_write_file "$file" FULL_STARTED_AT ""
  state_write_file "$file" FULL_JOB_ID ""
  state_write_file "$file" FULL_COMPLETED 0
  state_write_file "$file" FULL_COMPLETED_AT ""
  state_write_file "$file" FINAL_COMPLETED 0
  state_write_file "$file" FINAL_COMPLETED_AT ""
  state_write_file "$file" SOURCE_STOPPED 0
  state_write_file "$file" SOURCE_STOPPED_AT ""
}

migration_state_files_for_other_vm(){
  local vm="$1" wanted dir f base found=0
  wanted=".vmigrate-state-$(sanitize_name "$vm")"
  dir="$(config_dir)"
  shopt -s nullglob
  for f in "$dir"/.vmigrate-state-*; do
    base="${f##*/}"
    [[ "$base" == "$wanted" ]] && continue
    if state_file_progress_summary "$f"; then
      found=1
    fi
  done
  shopt -u nullglob
  (( found ))
}

migration_state_file_for_same_vm(){
  local vm="$1" file
  file="$(state_file_for_vm "$vm")"
  [[ -f "$file" ]] || return 1
  state_file_progress_summary "$file"
}

create_preparation_guard(){
  local vm="$1" tunnels jobs same_state states found=0 cleanup_needed=0
  tunnels="$(migration_active_tunnels || true)"
  jobs="$(migration_block_jobs_summary || true)"
  same_state="$(migration_state_file_for_same_vm "$vm" || true)"
  states="$(migration_state_files_for_other_vm "$vm" || true)"

  [[ -n "$tunnels" ]] && found=1 && cleanup_needed=1
  [[ -n "$jobs" ]] && found=1 && cleanup_needed=1
  [[ -n "$same_state" ]] && found=1
  [[ -n "$states" ]] && found=1
  (( found )) || return 0

  cat <<EOF

Previous migration artifacts detected:
EOF
  if [[ -n "$tunnels" ]]; then
    cat <<EOF

Active SSH/autossh tunnel(s):
$tunnels
EOF
  fi
  if [[ -n "$jobs" ]]; then
    cat <<EOF

QEMU block job(s) from the current config:
$jobs
EOF
  fi
  if [[ -n "$same_state" ]]; then
    cat <<EOF

Stale vmigrate state for this VM:
$same_state
EOF
  fi
  if [[ -n "$states" ]]; then
    cat <<EOF

Stale vmigrate state file(s) for other VM(s):
$states
EOF
  fi

  if [[ -n "$same_state" ]]; then
    echo
    echo "Starting a new migration for $vm requires resetting only the vmigrate state values above."
    ask_exact "Reset state values for $vm and continue? Type RESET:" "RESET" || die "Aborted"
    state_reset_migration_values_for_vm "$vm"
    ok "Reset vmigrate state values only: $(state_file_for_vm "$vm")"
  fi

  if [[ -n "$states" ]]; then
    echo
    echo "Other VM state files shown above were not modified."
    ask_exact "Leave those state files untouched and continue with $vm? Type CONTINUE:" "CONTINUE" || die "Aborted"
  fi

  if (( cleanup_needed )); then
    echo
    echo "Only local tunnel stop and concluded block-job dismiss will be attempted. State files, disks, LVs, VM definitions, and storage are not removed."
    if ! ask_yes_default "Attempt local tunnel/job cleanup and continue?"; then
      die "Aborted"
    fi
    if [[ -n "$tunnels" ]]; then
      if [[ -f "$CONFIG_FILE" && -n "$(get_conf TARGET_DISK)" ]]; then
        tunnel_stop || warn "No local tunnel stopped or tunnel-stop failed."
      else
        warn "Config is missing or incomplete, stopping detected local tunnel PID(s) directly."
        printf '%s\n' "$tunnels" | awk '{print $1}' | while read -r pid; do
          case "$pid" in
            ''|*[!0-9]*) continue ;;
          esac
          kill "$pid" 2>/dev/null || true
        done
      fi
    fi
    if [[ -n "$jobs" ]]; then
      [[ -f "$CONFIG_FILE" ]] || die "Cannot inspect block jobs because config is missing: $CONFIG_FILE"
      jobs_dismiss_all
    fi
    ok "Local tunnel/job cleanup attempt completed"
  fi
}

archive_config_snapshot(){
  local dst
  [[ -n "${RUN_DIR:-}" ]] || return 0
  [[ -f "$CONFIG_FILE" ]] || return 0
  dst="$RUN_DIR/config"
  [[ "$CONFIG_FILE" == "$dst" ]] && return 0
  cp -a "$CONFIG_FILE" "$dst" 2>/dev/null || warn "Could not write run config"
}

archive_report(){
  local name="${1:-report}" file
  [[ -n "${RUN_DIR:-}" ]] || return 0
  file="$RUN_DIR/${name}.txt"
  {
    echo "vmigrate archived report"
    echo "Generated at: $(now_ts)"
    echo "Run directory: $RUN_DIR"
    echo
    report
  } > "$file" 2>&1 || warn "Could not write archived report: $file"
  ok "Archived report: $file"
}

summary_file(){
  [[ -n "${RUN_DIR:-}" ]] || return 1
  printf '%s/summary.txt\n' "$RUN_DIR"
}

summary_set(){
  local key="$1" val="$2" file tmp
  file="$(summary_file)" || return 0
  mkdir -p "$(dirname "$file")"
  tmp="$(mktemp)"
  [[ -f "$file" ]] && grep -v -E "^${key}=" "$file" > "$tmp" || true
  printf '%s=%s\n' "$key" "$val" >> "$tmp"
  mv "$tmp" "$file"
}

summary_init(){
  local vm="$1" target_id="$2" target_host="$3" batch_id="${4:-}"
  summary_set VM "$vm"
  summary_set RUN_ID "${RUN_ID:-}"
  summary_set RUN_DIR "${RUN_DIR:-}"
  summary_set TARGET_ID "$target_id"
  summary_set TARGET_HOST "$target_host"
  summary_set BATCH_ID "$batch_id"
  summary_set START_TIME "$(now_ts)"
  summary_set START_EPOCH "$(date +%s)"
  summary_set RESULT "RUNNING"
  summary_set FULL_STATUS "PENDING"
  summary_set VERIFY "NOT_RUN"
  summary_set FINAL_STATUS "PENDING"
}

summary_finish(){
  local result="$1" full_status="${2:-}" end_epoch start_epoch duration
  end_epoch="$(date +%s)"
  start_epoch="$(awk -F= '$1=="START_EPOCH"{print $2; exit}' "$(summary_file 2>/dev/null)" 2>/dev/null || true)"
  [[ "$start_epoch" =~ ^[0-9]+$ ]] || start_epoch="$end_epoch"
  duration=$(( end_epoch - start_epoch ))

  summary_set END_TIME "$(now_ts)"
  summary_set END_EPOCH "$end_epoch"
  summary_set DURATION_SECONDS "$duration"
  summary_set DURATION "$(format_duration "$duration")"
  summary_set RESULT "$result"
  [[ -n "$full_status" ]] && summary_set FULL_STATUS "$full_status"
}

batch_run_dir(){
  local batch_id="$1"
  printf '%s/batches/%s\n' "${VMIGRATE_RUNS_DIR:-${SCRIPT_DIR}/migrations}" "$batch_id"
}

batch_write_line(){
  local batch_dir="$1" line="$2"
  mkdir -p "$batch_dir"
  printf '%s\n' "$line" >> "$batch_dir/summary.txt"
}

batch_remote_kill_nbd_port(){
  local port="${NBD_PORT:-10809}" host="${TARGET_HOST:-}" ssh_port="${SSH_PORT:-22}" ssh_user="${SSH_USER:-root}"
  [[ -n "$host" ]] || return 0
  warn "Checking stale remote qemu-nbd on ${host}:${port}"

  ssh -p "$ssh_port" -o BatchMode=yes -o ConnectTimeout=10 "${ssh_user}@${host}" "sh -c '
    line=\$(ss -lntp 2>/dev/null | grep \"127.0.0.1:${port}\" | grep qemu-nbd | head -n1 || true)
    [ -n \"\$line\" ] || exit 0
    pid=\$(printf \"%s\n\" \"\$line\" | sed -n \"s/.*pid=\\([0-9][0-9]*\\).*/\\1/p\" | head -n1)
    [ -n \"\$pid\" ] || exit 1
    echo \"Killing stale qemu-nbd pid=\$pid on port ${port}\"
    kill \"\$pid\" 2>/dev/null || true
    sleep 1
    if ss -lntp 2>/dev/null | grep \"127.0.0.1:${port}\" | grep -q qemu-nbd; then
      kill -9 \"\$pid\" 2>/dev/null || true
      sleep 1
    fi
    ss -lntp 2>/dev/null | grep \"127.0.0.1:${port}\" | grep qemu-nbd && exit 1 || exit 0
  '" || warn "Could not kill stale remote qemu-nbd on port $port"
}

batch_prepare_full_one(){
  local vm="$1" target_id="$2" target_host="$3" ssh_port="${4:-22}" ssh_user="${5:-root}" batch_id="${6:-}"
  [[ -n "$vm" && -n "$target_id" && -n "$target_host" ]] || die "batch entry requires: VM_NAME TARGET_ID TARGET_HOST [SSH_PORT] [SSH_USER]"
  case "$target_id" in *[!0-9]*|'') die "Target ID must be numeric: $target_id" ;; esac
  case "$ssh_port" in *[!0-9]*|'') die "SSH port must be numeric: $ssh_port" ;; esac

  IN_CREATE_WORKFLOW=1
  IN_BATCH_WORKFLOW=1
  start_log "$vm"
  lock_acquire "$vm"
  trap 'lock_release "$vm"; summary_finish "FAILED" "FAILED"' ERR

  CONFIG_FILE="${RUN_DIR}/config"
  : > "$CONFIG_FILE"
  chmod 600 "$CONFIG_FILE" 2>/dev/null || true
  activate_run_dir "$RUN_DIR"

  summary_init "$vm" "$target_id" "$target_host" "$batch_id"

  cat <<EOF
vmigrate batch-full item
------------------------
Source VM        : $vm
Target ID        : $target_id
Target host      : $target_host
SSH              : ${ssh_user}@${target_host}:${ssh_port}
Run directory    : $RUN_DIR
EOF

  remote_prepare "$vm" "$target_host" "$target_id" "$ssh_port" "$ssh_user" 0
  archive_config_snapshot
  preflight

  write_key BACKUP_METHOD drive-backup
  load_config

  # Ensure batch cleanup helpers use the batch connection settings.
  TARGET_HOST="$target_host"
  SSH_PORT="$ssh_port"
  SSH_USER="$ssh_user"

  # Batch mode is non-interactive. Clean stale tunnel/export for this run and retry once.
  tunnel_stop || true
  remote_dst_close || true
  batch_remote_kill_nbd_port || true

  remote_export || {
    warn "remote-export failed. Trying stale export cleanup and retrying once..."
    tunnel_stop || true
    remote_dst_close || true
    batch_remote_kill_nbd_port || true
    remote_export
  }

  start_tunnel
  tunnel_check || die "NBD metadata check failed. Fix tunnel/export before migration."

  create_bitmap
  check_bitmap
  archive_report "report.pre-full"

  if ! block_jobs_empty; then
    warn "Existing block job found before FULL sync."
    jobs_cmd
    warn "Trying to dismiss concluded/stale jobs before FULL sync."
    jobs_dismiss_all
    if ! block_jobs_empty; then
      jobs_cmd
      die "A block job is still present. Resolve it before starting FULL sync."
    fi
  fi

  full_sync
  wait_full
  archive_report "report.after-full"

  summary_finish "SUCCESS" "AFTER_FULL"
  lock_release "$vm"
  trap - ERR

  # Batch mode must free the common port/export before moving to the next VM.
  # This does not remove the bitmap or any migrated data.
  tunnel_stop || warn "Tunnel stop failed or no tunnel found."
  remote_dst_close || warn "Remote NBD close failed or no export found."

  ok "Batch FULL completed for $vm"
}

batch_full(){
  local file="${1:-}" batch_id batch_dir line vm target_id target_host ssh_port ssh_user idx=0 ok_count=0 fail_count=0 skip_count=0 rc
  [[ -n "$file" ]] || die "Usage: ./vmigrate batch-full BATCH_FILE"
  [[ -f "$file" ]] || die "Batch file not found: $file"

  batch_id="$(date '+%Y%m%d-%H%M%S')"
  batch_dir="$(batch_run_dir "$batch_id")"
  mkdir -p "$batch_dir"
  cp -a "$file" "$batch_dir/batch.txt"

  {
    echo "BATCH_ID=$batch_id"
    echo "START_TIME=$(now_ts)"
    echo "BATCH_FILE=$file"
    echo
  } > "$batch_dir/summary.txt"

  ok "Batch directory: $batch_dir"

  set +e
  exec 3< "$file"
  while IFS= read -r line <&3 || [[ -n "$line" ]]; do
    line="${line%%#*}"
    line="$(printf '%s' "$line" | awk '{$1=$1; print}')"
    [[ -n "$line" ]] || continue

    idx=$((idx + 1))
    set -- $line
    vm="${1:-}"
    target_id="${2:-}"
    target_host="${3:-}"
    ssh_port="${4:-22}"
    ssh_user="${5:-root}"

    if [[ -z "$vm" || -z "$target_id" || -z "$target_host" ]]; then
      warn "Skipping invalid batch line $idx: $line"
      batch_write_line "$batch_dir" "ITEM_$idx=SKIPPED invalid-line"
      skip_count=$((skip_count + 1))
      continue
    fi

    echo
    echo "[$idx] $vm -> target $target_id"
    echo "--------------------------------"

    RUN_ID="${batch_id}-${idx}"
    run_dir="${VMIGRATE_RUNS_DIR:-${SCRIPT_DIR}/migrations}/$(sanitize_name "$vm")/${RUN_ID}"

    set +e
    (
      set +e
      RUN_ID="$RUN_ID"
      VMIGRATE_LOG="${VMIGRATE_LOG:-1}"
      batch_prepare_full_one "$vm" "$target_id" "$target_host" "$ssh_port" "$ssh_user" "$batch_id"
      exit $?
    ) < /dev/null
    rc=$?
    set +e

    if [[ "$rc" -eq 0 ]]; then
      ok "Batch item completed: $vm"
      batch_write_line "$batch_dir" "$vm $RUN_ID SUCCESS $run_dir"
      ok_count=$((ok_count + 1))
    else
      warn "Batch item failed: $vm"
      batch_write_line "$batch_dir" "$vm $RUN_ID FAILED rc=$rc $run_dir"
      fail_count=$((fail_count + 1))
      continue
    fi
  done
  exec 3<&-
  set -e

  {
    echo
    echo "END_TIME=$(now_ts)"
    echo "SUCCESS_COUNT=$ok_count"
    echo "FAILED_COUNT=$fail_count"
    echo "SKIPPED_COUNT=$skip_count"
  } >> "$batch_dir/summary.txt"

  echo
  echo "Batch finished"
  echo "--------------"
  echo "Success : $ok_count"
  echo "Failed  : $fail_count"
  echo "Skipped : $skip_count"
  echo "Summary : $batch_dir/summary.txt"

  [[ "$fail_count" -eq 0 ]]
}


lock_dir(){ printf '%s/locks\n' "$SCRIPT_DIR"; }
lock_path_for_vm(){ printf '%s/%s.lock\n' "$(lock_dir)" "$(sanitize_name "$1")"; }

lock_acquire(){
  local vm="$1" lock path now oldpid oldcmd
  [[ -n "$vm" ]] || die "lock_acquire requires VM name"
  mkdir -p "$(lock_dir)"
  lock="$(lock_path_for_vm "$vm")"

  if mkdir "$lock" 2>/dev/null; then
    {
      echo "VM=$vm"
      echo "PID=$$"
      echo "START_TIME=$(now_ts)"
      echo "COMMAND=${0##*/} ${*:-}"
      echo "RUN_DIR=${RUN_DIR:-}"
    } > "$lock/info"
    return 0
  fi

  oldpid="$(awk -F= '$1=="PID"{print $2; exit}' "$lock/info" 2>/dev/null || true)"
  if [[ -n "$oldpid" ]] && kill -0 "$oldpid" 2>/dev/null; then
    echo "Active lock found:"
    cat "$lock/info" 2>/dev/null || true
    die "Another vmigrate operation is already running for VM: $vm"
  fi

  warn "Stale lock detected for $vm; removing: $lock"
  rm -rf "$lock"
  mkdir "$lock" || die "Could not acquire lock: $lock"
  {
    echo "VM=$vm"
    echo "PID=$$"
    echo "START_TIME=$(now_ts)"
    echo "COMMAND=${0##*/} ${*:-}"
    echo "RUN_DIR=${RUN_DIR:-}"
  } > "$lock/info"
}

lock_release(){
  local vm="$1" lock pid
  [[ -n "$vm" ]] || return 0
  lock="$(lock_path_for_vm "$vm")"
  [[ -d "$lock" ]] || return 0
  pid="$(awk -F= '$1=="PID"{print $2; exit}' "$lock/info" 2>/dev/null || true)"
  [[ "$pid" == "$$" || -z "$pid" ]] && rm -rf "$lock"
}

lock_status(){
  local base found=0 f pid vm start run cmd status age now start_epoch
  base="$(lock_dir)"
  [[ -d "$base" ]] || { echo "No locks."; return 0; }

  printf '%-18s %-8s %-8s %-20s %s\n' "VM" "STATUS" "PID" "AGE" "RUN_DIR"

  shopt -s nullglob
  now="$(date +%s)"

  for f in "$base"/*.lock; do
    found=1

    vm="$(awk -F= '$1=="VM"{print $2; exit}' "$f/info" 2>/dev/null || true)"
    pid="$(awk -F= '$1=="PID"{print $2; exit}' "$f/info" 2>/dev/null || true)"
    start="$(awk -F= '$1=="START_TIME"{print $2; exit}' "$f/info" 2>/dev/null || true)"
    run="$(awk -F= '$1=="RUN_DIR"{print $2; exit}' "$f/info" 2>/dev/null || true)"

    [[ -n "$vm" ]] || vm="${f##*/}"
    vm="${vm%.lock}"

    if [[ -n "$pid" ]] && kill -0 "$pid" 2>/dev/null; then
      status="active"
    else
      status="stale"
    fi

    age="unknown"
    if [[ -n "$start" ]]; then
      start_epoch="$(date -d "$start" +%s 2>/dev/null || true)"
      if [[ -n "$start_epoch" && "$start_epoch" =~ ^[0-9]+$ ]]; then
        age="$(format_duration "$(( now - start_epoch ))")"
      fi
    fi

    [[ -n "$run" ]] || run="-"

    printf '%-18s %-8s %-8s %-20s %s\n' "$vm" "$status" "${pid:-"-"}" "$age" "$run"
  done

  shopt -u nullglob
  (( found )) || echo "No locks."
}

unlock_stale_one(){
  local lock="$1" name pid
  [[ -d "$lock" ]] || return 1

  name="${lock##*/}"
  name="${name%.lock}"
  pid="$(awk -F= '$1=="PID"{print $2; exit}' "$lock/info" 2>/dev/null || true)"

  if [[ -n "$pid" ]] && kill -0 "$pid" 2>/dev/null; then
    warn "Active lock kept: $name (pid $pid)"
    return 2
  fi

  rm -rf "$lock"
  ok "Removed stale lock: $name"
  return 0
}

unlock_stale_cmd(){
  local base f removed=0 active=0 found=0 rc
  base="$(lock_dir)"

  echo "Scanning locks..."
  echo

  [[ -d "$base" ]] || {
    echo "No locks."
    return 0
  }

  shopt -s nullglob
  for f in "$base"/*.lock; do
    found=1
    set +e
    unlock_stale_one "$f"
    rc=$?
    set -e

    case "$rc" in
      0) removed=$((removed+1)) ;;
      2) active=$((active+1)) ;;
    esac
  done
  shopt -u nullglob

  if [[ "$found" -eq 0 ]]; then
    echo "No locks."
    return 0
  fi

  cat <<EOF

Summary
-------
Removed : $removed
Active  : $active
EOF
}

shell_quote(){
  local s="$1"
  printf "'%s'" "$(printf '%s' "$s" | sed "s/'/'\\\\''/g")"
}

force_tunnel_stop(){
  local pids
  pids="$(migration_active_tunnels 2>/dev/null | awk '{print $1}' | sort -u || true)"
  if [[ -z "$pids" ]]; then
    warn "No matching tunnel process found for force kill."
    return 0
  fi

  warn "Force killing local tunnel PID(s): $pids"
  kill $pids 2>/dev/null || true
  sleep 1

  for pid in $pids; do
    if kill -0 "$pid" 2>/dev/null; then
      warn "Force killing stubborn tunnel PID: $pid"
      kill -KILL "$pid" 2>/dev/null || true
    fi
  done
}

remote_force_kill_qemu_nbd(){
  load_config

  local qdisk qexport cmd
  qdisk="$(shell_quote "$TARGET_DISK")"
  qexport="$(shell_quote "$NBD_EXPORT")"

  cmd="pids=\$(ps -eo pid=,args= | grep '[q]emu-nbd' | grep -F -- $qdisk | awk '{print \$1}' | sort -u); \
if [ -z \"\$pids\" ]; then \
  pids=\$(ps -eo pid=,args= | grep '[q]emu-nbd' | grep -F -- $qexport | awk '{print \$1}' | sort -u); \
fi; \
if [ -z \"\$pids\" ]; then \
  echo 'No matching remote qemu-nbd process found'; exit 0; \
fi; \
echo \"Force killing remote qemu-nbd PID(s): \$pids\"; \
kill \$pids 2>/dev/null || true; \
sleep 1; \
for p in \$pids; do \
  if kill -0 \$p 2>/dev/null; then \
    kill -KILL \$p 2>/dev/null || true; \
  fi; \
done; exit 0"

  remote_ssh "$cmd"
}

cleanup_stale(){
  load_config

  local force=0 arg
  for arg in "$@"; do
    case "$arg" in
      --force) force=1 ;;
      -h|--help)
        cat <<EOF
Usage:
  ./vmigrate cleanup-stale
  ./vmigrate cleanup-stale --force

Safe mode:
  - stop matching local tunnel
  - close remote export through vmigrate-agent
  - dismiss concluded QMP jobs
  - remove stale lock only if PID is dead

Force mode:
  - everything in safe mode
  - force kill matching local tunnel PID(s)
  - force kill remote qemu-nbd matching TARGET_DISK or NBD_EXPORT

Force mode requires typing FORCE.
EOF
        return 0
        ;;
      *)
        die "Unknown cleanup-stale option: $arg"
        ;;
    esac
  done

  echo "cleanup-stale"
  echo "-------------"
  echo "VM        : $VM_NAME"
  echo "Target    : ${TARGET_SSH_USER}@${TARGET_HOST}:${TARGET_SSH_PORT}"
  echo "NBD       : 127.0.0.1:${NBD_PORT}, export=${NBD_EXPORT}"
  echo "Target disk: $TARGET_DISK"
  echo "Run config: $CONFIG_FILE"
  echo

  if [[ "$force" -eq 1 ]]; then
    warn "FORCE mode enabled."
    warn "This will kill matching local tunnel processes and remote qemu-nbd processes."
    echo
    ask_exact "Continue cleanup-stale --force? Type FORCE:" "FORCE" || die "Aborted"
  else
    echo "This only attempts safe cleanup for the active/current config:"
    echo "- stop local SSH/autossh tunnel for this NBD port/target"
    echo "- close remote destination NBD export through vmigrate-agent"
    echo "- dismiss concluded QMP block jobs"
    echo "- remove stale local lock for this VM if PID is dead"
    echo
    ask_exact "Continue cleanup-stale? Type CLEAN:" "CLEAN" || die "Aborted"
  fi

  tunnel_stop || warn "Local tunnel stop failed or no matching tunnel was found."
  remote_dst_close || warn "Remote NBD close failed or no export was found."

  set +e
  ( jobs_dismiss_all )
  local dismiss_rc=$?
  set -e
  [[ "$dismiss_rc" -eq 0 ]] || warn "QMP job dismiss failed or timed out; continuing cleanup."

  if [[ "$force" -eq 1 ]]; then
    force_tunnel_stop || warn "Force tunnel cleanup failed"
    remote_force_kill_qemu_nbd || warn "Force remote qemu-nbd cleanup returned non-zero; continuing."
  fi

  local lock
  lock="$(lock_path_for_vm "$VM_NAME")"
  if [[ -d "$lock" ]]; then
    unlock_stale_one "$lock" || true
  fi

  ok "cleanup-stale completed"
}

history_cmd(){
  local filter_vm="" mode="latest" arg base found=0 shown=0

  while [[ $# -gt 0 ]]; do
    arg="$1"
    case "$arg" in
      --latest|latest) mode="latest" ;;
      --all|all) mode="all" ;;
      --failed|failed) mode="failed" ;;
      -h|--help)
        cat <<EOF
Usage:
  ./vmigrate history
  ./vmigrate history --latest
  ./vmigrate history --all
  ./vmigrate history --failed

  ./vmigrate history VM_NAME
  ./vmigrate history VM_NAME --all
  ./vmigrate history VM_NAME --failed

Aliases:
  latest, all, failed

Columns:
  VM, RUN_ID, STATUS, FULL, FINAL, VERIFY, REL_DIR
EOF
        return 0
        ;;
      *)
        filter_vm="$arg"
        ;;
    esac
    shift
  done

  base="$(runs_base_dir)"

  printf '%-18s %-20s %-15s %-5s %-5s %-8s %s\n' "VM" "RUN_ID" "STATUS" "FULL" "FINAL" "VERIFY" "REL_DIR"

  shopt -s nullglob

  if [[ "$mode" == "latest" ]]; then
    local vmdir dir vm run cfg cfg_vm status full final verify rel_dir state safe_vm
    for vmdir in "$base"/*; do
      [[ -d "$vmdir" ]] || continue
      [[ "${vmdir##*/}" == "batches" ]] && continue

      vm="${vmdir##*/}"
      [[ -n "$filter_vm" && "$vm" != "$(sanitize_name "$filter_vm")" && "$vm" != "$filter_vm" ]] && continue

      dir="$(ls -1d "$vmdir"/* 2>/dev/null | sort | tail -n1)"
      [[ -n "$dir" && -d "$dir" ]] || continue

      run="${dir##*/}"
      cfg="$dir/config"
      if [[ -f "$cfg" ]]; then
        cfg_vm="$(run_config_value "$cfg" VM_NAME)"
        [[ -n "$cfg_vm" ]] && vm="$cfg_vm"
      fi

      status="$(run_status_for_dir "$dir")"
      full="no"; final="no"
      safe_vm="$(sanitize_name "$vm")"
      state="$dir/.vmigrate-state-$safe_vm"
      [[ "$(state_get_from_file "$state" FULL_COMPLETED)" == "1" ]] && full="yes"
      [[ "$(state_get_from_file "$state" FINAL_COMPLETED)" == "1" ]] && final="yes"

      verify="NOT_RUN"
      [[ -f "$dir/summary.txt" ]] && verify="$(awk -F= '$1=="VERIFY"{print $2; exit}' "$dir/summary.txt")"
      [[ -n "$verify" ]] || verify="NOT_RUN"

      rel_dir="migrations/${dir#"$base"/}"
      printf '%-18s %-20s %-15s %-5s %-5s %-8s %s\n' "$vm" "$run" "$status" "$full" "$final" "$verify" "$rel_dir"
      shown=$((shown+1))
    done
    shopt -u nullglob
    (( shown )) || warn "No matching migration runs found."
    return 0
  fi

  local dir vm run cfg cfg_vm status full final verify rel_dir state safe_vm
  for dir in "$base"/*/*; do
    [[ -d "$dir" ]] || continue
    case "$dir" in "$base"/batches/*) continue ;; esac
    found=1

    vm="${dir%/*}"
    vm="${vm##*/}"
    run="${dir##*/}"
    cfg="$dir/config"

    if [[ -f "$cfg" ]]; then
      cfg_vm="$(run_config_value "$cfg" VM_NAME)"
      [[ -n "$cfg_vm" ]] && vm="$cfg_vm"
    fi

    [[ -n "$filter_vm" && "$vm" != "$filter_vm" && "$(sanitize_name "$vm")" != "$(sanitize_name "$filter_vm")" ]] && continue

    status="$(run_status_for_dir "$dir")"
    full="no"; final="no"
    safe_vm="$(sanitize_name "$vm")"
    state="$dir/.vmigrate-state-$safe_vm"
    [[ "$(state_get_from_file "$state" FULL_COMPLETED)" == "1" ]] && full="yes"
    [[ "$(state_get_from_file "$state" FINAL_COMPLETED)" == "1" ]] && final="yes"

    verify="NOT_RUN"
    [[ -f "$dir/summary.txt" ]] && verify="$(awk -F= '$1=="VERIFY"{print $2; exit}' "$dir/summary.txt")"
    [[ -n "$verify" ]] || verify="NOT_RUN"

    if [[ "$mode" == "failed" ]]; then
      [[ "$status" == *failed* || "$verify" == "FAIL" ]] || continue
    fi

    rel_dir="migrations/${dir#"$base"/}"
    printf '%-18s %-20s %-15s %-5s %-5s %-8s %s\n' "$vm" "$run" "$status" "$full" "$final" "$verify" "$rel_dir"
    shown=$((shown+1))
  done

  shopt -u nullglob
  (( shown )) || warn "No matching migration runs found."
}

create_workflow(){
  local vm="$1" target_id="$2" target_host="$3" ssh_port="${4:-22}" ssh_user="${5:-root}"

  [[ -n "$vm" && -n "$target_id" && -n "$target_host" ]] || die "Usage: ./vmigrate create VM_NAME TARGET_ID TARGET_HOST [SSH_PORT] [SSH_USER]"
  case "$target_id" in *[!0-9]*|'') die "Target ID must be numeric" ;; esac
  case "$ssh_port" in *[!0-9]*|'') die "SSH port must be numeric" ;; esac
  [[ -n "$ssh_user" ]] || die "SSH user must not be empty"

  IN_CREATE_WORKFLOW=1
  start_log "$vm"
  lock_acquire "$vm"
  trap 'lock_release "$vm"' EXIT

  cat <<EOF
vmigrate migration
-----------------
Source VM        : $vm
Target ID        : $target_id
Target host      : $target_host
SSH              : ${ssh_user}@${target_host}:${ssh_port}
Backup method    : drive-backup
EOF

  create_preparation_guard "$vm"
  ask_exact "Continue with preparation? Type YES:" "YES" || die "Aborted"

  CONFIG_FILE="${RUN_DIR}/config"
  : > "$CONFIG_FILE"
  chmod 600 "$CONFIG_FILE" 2>/dev/null || true
  activate_run_dir "$RUN_DIR"

  remote_prepare "$vm" "$target_host" "$target_id" "$ssh_port" "$ssh_user" 0
  archive_config_snapshot
  preflight

  write_key BACKUP_METHOD drive-backup
  load_config

  # Batch mode is non-interactive. If a previous export/tunnel was left open
  # for the same run/config, clean it safely and retry instead of failing.
  tunnel_stop || true
  remote_dst_close || true

  remote_export || {
    warn "remote-export failed. Trying stale export cleanup and retrying once..."
    tunnel_stop || true
    remote_dst_close || true
    remote_export
  }

  start_tunnel
  tunnel_check || die "NBD metadata check failed. Fix tunnel/export before migration."

  create_bitmap
  check_bitmap
  report
  archive_report "report.pre-full"

  if ! block_jobs_empty; then
    warn "Existing block job found before FULL sync."
    jobs_cmd
    warn "Trying to dismiss concluded/stale jobs before FULL sync."
    jobs_dismiss_all
    if ! block_jobs_empty; then
      jobs_cmd
      die "A block job is still present. Resolve it before starting FULL sync."
    fi
  fi

  cat <<EOF

Preparation completed.
Ready to start FULL sync.
EOF
  if ! ask_exact "Start FULL sync now? Type FULL:" "FULL"; then
    cat <<EOF
Full sync not started.
Resume manually:
  ./vmigrate full
  ./vmigrate wait-full
EOF
    return 0
  fi

  full_sync
  wait_full
  report
  archive_report "report.after-full"

  cat <<EOF

FULL sync completed.
Cutover will suspend the source VM and run final incremental.
Lock customer/Virtualizor controls before continuing.
EOF
  if ! ask_exact "Start CUTOVER now? Type CUTOVER:" "CUTOVER"; then
    cat <<EOF
Cutover not started.
Resume manually:
  ./vmigrate cutover-check
  ./vmigrate final
  ./vmigrate report
EOF
    return 0
  fi

  if ask_yes_default "Run pre-cutover incremental sync first?"; then
    cat <<EOF

Starting pre-cutover incremental sync while source VM remains running...
EOF
    incremental_sync
    wait_inc

    echo
    report

    cat <<EOF

Pre-cutover incremental completed.
Source VM is still running.
EOF
  fi

  final_cutover_run
  report
  archive_report "report.final"

  cat <<EOF

Cutover completed.
Destination VM is ready to boot.
Source VM still exists unless stopped.
EOF
  if ask_exact "Stop source VM now (irreversible for production traffic)? Type STOP:" "STOP"; then
    stop_source_run
  else
    cat <<EOF
Source VM was not stopped.
The source VM is suspended after final cutover, not running.
Do not resume it unless you are intentionally rolling back.
You can stop later:
  ./vmigrate stop-source
EOF
  fi

  if ask_exact "Close destination NBD export and local tunnel now? Type CLEAN:" "CLEAN"; then
    tunnel_stop || warn "Tunnel stop failed or no tunnel found."
    remote_dst_close || warn "Remote NBD close failed or no export found."
    ok "Cleanup completed"
  else
    cat <<EOF
Cleanup skipped.
You can clean later:
  ./vmigrate tunnel-stop
  ./vmigrate remote-dst-close
EOF
  fi

  cat <<EOF
Migration workflow finished.
Review:
  ./vmigrate report
EOF
  lock_release "$vm"
  trap - EXIT
}

