  report_kv "Effective method" "$(effective_backup_method)"
  report_kv "State file" "$(state_file)"
  report_kv "FULL_STARTED" "$(state_get FULL_STARTED)"
  report_kv "FULL_STARTED_AT" "$(state_get FULL_STARTED_AT)"
  report_kv "FULL_JOB_ID" "$(state_get FULL_JOB_ID)"
  report_kv "FULL_COMPLETED" "$(state_get FULL_COMPLETED)"
  report_kv "FULL_COMPLETED_AT" "$(state_get FULL_COMPLETED_AT)"
  report_kv "FINAL_COMPLETED" "$(state_get FINAL_COMPLETED)"
  report_kv "FINAL_COMPLETED_AT" "$(state_get FINAL_COMPLETED_AT)"
  report_kv "SOURCE_STOPPED" "$(state_get SOURCE_STOPPED)"
  report_kv "SOURCE_STOPPED_AT" "$(state_get SOURCE_STOPPED_AT)"

  if command -v virsh >/dev/null 2>&1; then
    report_kv "VM state" "$(virsh domstate "$VM_NAME" 2>/dev/null || echo unknown)"
  else
    report_kv "VM state" "virsh not found"
  fi
  report_kv "Active block jobs" ""
  if out="$(block_jobs_json 2>/dev/null)"; then
