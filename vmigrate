#!/usr/bin/env bash
# vmigrate source-side helper
set -Eeuo pipefail

VERSION="0.4.3"
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
CONFIG_FILE="${VMIGRATE_CONFIG:-${SCRIPT_DIR}/vmigrate.env}"

RED=$'\033[0;31m'; GREEN=$'\033[0;32m'; YELLOW=$'\033[1;33m'; BLUE=$'\033[0;34m'; NC=$'\033[0m'
if [[ -n "${NO_COLOR:-}" ]]; then
  RED=""; GREEN=""; YELLOW=""; BLUE=""; NC=""
fi
info(){ echo "${BLUE}>>${NC} $*"; }
ok(){ echo "${GREEN}OK${NC} $*"; }
warn(){ echo "${YELLOW}WARN${NC} $*"; }
die(){ echo "${RED}ERROR${NC} $*" >&2; exit 1; }
need(){ command -v "$1" >/dev/null 2>&1 || die "Required command not found: $1"; }

usage(){ cat <<EOF
vmigrate v${VERSION}

Usage:
  ./vmigrate discover [VM_NAME] [--yes]
  ./vmigrate init
  ./vmigrate show
  ./vmigrate apply-handoff HANDOFF_TOKEN
  ./vmigrate remote-prepare VM_NAME TARGET_ID TARGET_HOST [SSH_PORT] [SSH_USER]
  ./vmigrate create VM_NAME TARGET_ID TARGET_HOST [SSH_PORT] [SSH_USER]
  ./vmigrate remote-export
  ./vmigrate remote-dst-status
  ./vmigrate remote-dst-close
  ./vmigrate quick [HANDOFF_TOKEN]
  ./vmigrate quick [VM_NAME] [HANDOFF_TOKEN]
  ./vmigrate next
  ./vmigrate doctor
  ./vmigrate tunnel
  ./vmigrate tunnel-stop
  ./vmigrate tunnel-restart
  ./vmigrate tunnel-status
  ./vmigrate tunnel-check
  ./vmigrate attach-target
  ./vmigrate check-target
  ./vmigrate bitmap
  ./vmigrate check-bitmap
  ./vmigrate full
  ./vmigrate wait-full
  ./vmigrate mark-full
  ./vmigrate set-backup-method
  ./vmigrate incremental
  ./vmigrate wait-inc
  ./vmigrate jobs
  ./vmigrate job-dismiss JOB_ID
  ./vmigrate jobs-dismiss-all
  ./vmigrate cutover-check
  ./vmigrate check-paused
  ./vmigrate final
  ./vmigrate watch
  ./vmigrate status
  ./vmigrate report
  ./vmigrate verify-sample
  ./vmigrate cleanup
  ./vmigrate stop-source

Recommended first run:
  ./vmigrate quick HANDOFF_TOKEN
EOF
}

ask(){ local var="$1" prompt="$2" def="${3:-}" val; read -r -p "$prompt${def:+ [$def]}: " val; printf -v "$var" '%s' "${val:-$def}"; }
confirm(){ local prompt="$1" ans; read -r -p "$prompt [yes/no]: " ans; [[ "$ans" == "yes" ]]; }
ask_exact(){
  local prompt="$1" expected="$2" ans
  read -r -p "$prompt " ans
  [[ "$ans" == "$expected" ]]
}
ask_yes_default(){
  local prompt="$1" ans
  while true; do
    read -r -p "$prompt [Y/n]: " ans
    case "$ans" in
      ""|Y|y) return 0 ;;
      N|n) return 1 ;;
      *) echo "Please answer Y or N." ;;
    esac
  done
}

sanitize_name(){ printf '%s' "$1" | tr -c 'A-Za-z0-9_.-' '-'; }
default_bitmap(){ printf 'vmigrate-bitmap-%s' "$(sanitize_name "$1")"; }
default_target_node(){ printf 'vmigrate-target-%s' "$(sanitize_name "$1")"; }

load_config(){
  [[ -f "$CONFIG_FILE" ]] || die "Config not found: $CONFIG_FILE. Run: ./vmigrate discover VM_NAME"
  # shellcheck disable=SC1090
  source "$CONFIG_FILE"
  : "${VM_NAME:?}"; : "${TARGET_HOST:?}"; : "${TARGET_SSH_USER:=root}"; : "${TARGET_SSH_PORT:=22}"; : "${TARGET_ID:?}"; : "${TARGET_DISK:?}"
  SRC_DISK="${SRC_DISK:-}"
  QEMU_DEVICE="${QEMU_DEVICE:-}"
  QEMU_NODE="${QEMU_NODE:-}"
  BITMAP="${BITMAP:-$(default_bitmap "$VM_NAME")}"
  TARGET_NODE="${TARGET_NODE:-$(default_target_node "$VM_NAME")}"
  NBD_PORT="${NBD_PORT:-10809}"
  NBD_EXPORT="${NBD_EXPORT:-vm-${TARGET_ID}}"
  TUNNEL_MODE="${TUNNEL_MODE:-autossh}"
  AUTOSSH_MONITOR_PORT="${AUTOSSH_MONITOR_PORT:-20000}"
  BACKUP_METHOD="${BACKUP_METHOD:-drive-backup}"
  QMP_TIMEOUT="${QMP_TIMEOUT:-20}"
  CHECK_TIMEOUT="${CHECK_TIMEOUT:-8}"
  NBD_IO_TIMEOUT="${NBD_IO_TIMEOUT:-20}"
}

get_conf(){ local key="$1"; [[ -f "$CONFIG_FILE" ]] || return 0; awk -F= -v k="$key" '$1==k {print substr($0, index($0,"=")+1); exit}' "$CONFIG_FILE"; }
write_key(){
  local key="$1" val="$2" tmp
  tmp="$(mktemp)"
  [[ -f "$CONFIG_FILE" ]] && grep -v -E "^${key}=" "$CONFIG_FILE" > "$tmp" || true
  printf '%s=%s\n' "$key" "$val" >> "$tmp"
  mv "$tmp" "$CONFIG_FILE"
}

now_ts(){ date '+%Y-%m-%d %H:%M:%S %z'; }
config_dir(){ case "$CONFIG_FILE" in */*) printf '%s' "${CONFIG_FILE%/*}" ;; *) printf '.' ;; esac; }
state_file(){
  local vm
  vm="${VM_NAME:-$(get_conf VM_NAME)}"
  [[ -n "$vm" ]] || vm="unknown"
  state_file_for_vm "$vm"
}
state_file_for_vm(){ printf '%s/.vmigrate-state-%s' "$(config_dir)" "$(sanitize_name "$1")"; }
state_get(){ local key="$1" file; file="$(state_file)"; [[ -f "$file" ]] || return 0; awk -F= -v k="$key" '$1==k {print substr($0, index($0,"=")+1); exit}' "$file"; }
state_get_from_file(){ local file="$1" key="$2"; [[ -f "$file" ]] || return 0; awk -F= -v k="$key" '$1==k {print substr($0, index($0,"=")+1); exit}' "$file"; }
state_write_file(){
  local file="$1" key="$2" val="$3" tmp
  tmp="$(mktemp)"
  [[ -f "$file" ]] && grep -v -E "^${key}=" "$file" > "$tmp" || true
  printf '%s=%s\n' "$key" "$val" >> "$tmp"
  mv "$tmp" "$file"
  chmod 600 "$file" 2>/dev/null || true
}
state_write(){
  local key="$1" val="$2" file
  file="$(state_file)"
  state_write_file "$file" "$key" "$val"
}
state_sync_identity(){
  state_write VM_NAME "${VM_NAME:-}"
  state_write SRC_DISK "${SRC_DISK:-}"
  state_write TARGET_DISK "${TARGET_DISK:-}"
  [[ -n "$(state_get FULL_STARTED)" ]] || state_write FULL_STARTED 0
  [[ -n "$(state_get FULL_STARTED_AT)" ]] || state_write FULL_STARTED_AT ""
  [[ -n "$(state_get FULL_JOB_ID)" ]] || state_write FULL_JOB_ID ""
  [[ -n "$(state_get FULL_COMPLETED)" ]] || state_write FULL_COMPLETED 0
  [[ -n "$(state_get FULL_COMPLETED_AT)" ]] || state_write FULL_COMPLETED_AT ""
  [[ -n "$(state_get FINAL_COMPLETED)" ]] || state_write FINAL_COMPLETED 0
  [[ -n "$(state_get FINAL_COMPLETED_AT)" ]] || state_write FINAL_COMPLETED_AT ""
  [[ -n "$(state_get SOURCE_STOPPED)" ]] || state_write SOURCE_STOPPED 0
  [[ -n "$(state_get SOURCE_STOPPED_AT)" ]] || state_write SOURCE_STOPPED_AT ""
}
state_is_full_completed(){ [[ "$(state_get FULL_COMPLETED)" == "1" ]]; }
state_is_final_completed(){ [[ "$(state_get FINAL_COMPLETED)" == "1" ]]; }
require_full_completed(){
  state_is_full_completed && return 0
  die "Full sync is not marked as completed. Refusing incremental/final. Run wait-full or mark-full only after confirming full completed successfully."
}
require_final_completed(){
  state_is_final_completed && return 0
  die "FINAL_COMPLETED=1 is not present in $(state_file). Refusing to stop/destroy the source VM."
}
mark_full_completed(){
  load_config
  state_sync_identity
  state_write FULL_COMPLETED 1
  state_write FULL_COMPLETED_AT "$(now_ts)"
}

init_config(){
  local vm target_host target_id target_disk ssh_port src_disk
  ask vm "Source VM name" "kvm3023"
  ask target_host "Target host/IP" "CHANGE_ME"
  ask ssh_port "Target SSH port" "22"
  ask target_id "Target ID" "2672"
  ask target_disk "Target disk path" "/dev/pve/vm-${target_id}-disk-0"
  ask src_disk "Source disk path, empty=auto-discover" ""
  cat > "$CONFIG_FILE" <<EOF
VM_NAME=$vm
SRC_DISK=$src_disk
QEMU_DEVICE=
QEMU_NODE=
BITMAP=$(default_bitmap "$vm")
TARGET_NODE=$(default_target_node "$vm")
TARGET_HOST=$target_host
TARGET_SSH_USER=root
TARGET_SSH_PORT=$ssh_port
TARGET_ID=$target_id
TARGET_DISK=$target_disk
NBD_PORT=10809
NBD_EXPORT=vm-${target_id}
TUNNEL_MODE=autossh
AUTOSSH_MONITOR_PORT=20000
BACKUP_METHOD=drive-backup
EOF
  chmod 600 "$CONFIG_FILE"
  ok "Config written: $CONFIG_FILE"
}

ensure_base_config(){
  local vm_arg="${1:-}" vm old_vm target_host target_id target_disk ssh_port
  if [[ -f "$CONFIG_FILE" ]]; then
    old_vm="$(get_conf VM_NAME)"
    vm="${vm_arg:-$old_vm}"
    [[ -n "$vm" ]] || ask vm "Source VM name" "kvm3023"
    write_key VM_NAME "$vm"

    if [[ -n "$old_vm" && "$vm" != "$old_vm" ]]; then
      warn "VM changed from $old_vm to $vm; regenerating VM-specific values"
      write_key SRC_DISK ""
      write_key QEMU_DEVICE ""
      write_key QEMU_NODE ""
      write_key BITMAP "$(default_bitmap "$vm")"
      write_key TARGET_NODE "$(default_target_node "$vm")"
    else
      [[ -n "$(get_conf BITMAP)" ]] || write_key BITMAP "$(default_bitmap "$vm")"
      [[ -n "$(get_conf TARGET_NODE)" ]] || write_key TARGET_NODE "$(default_target_node "$vm")"
      [[ -n "$(get_conf NBD_EXPORT)" ]] || write_key NBD_EXPORT "vm-$(get_conf TARGET_ID)"
    fi

    [[ -n "$(get_conf TARGET_SSH_USER)" ]] || write_key TARGET_SSH_USER root
    [[ -n "$(get_conf TARGET_SSH_PORT)" ]] || write_key TARGET_SSH_PORT 22
    [[ -n "$(get_conf NBD_PORT)" ]] || write_key NBD_PORT 10809
    [[ -n "$(get_conf TUNNEL_MODE)" ]] || write_key TUNNEL_MODE autossh
    [[ -n "$(get_conf AUTOSSH_MONITOR_PORT)" ]] || write_key AUTOSSH_MONITOR_PORT 20000
    [[ -n "$(get_conf BACKUP_METHOD)" ]] || write_key BACKUP_METHOD drive-backup
  else
    vm="$vm_arg"
    [[ -n "$vm" ]] || ask vm "Source VM name" "kvm3023"
    ask target_host "Target host/IP" "CHANGE_ME"
    ask ssh_port "Target SSH port" "22"
    ask target_id "Target ID" "2672"
    ask target_disk "Target disk path" "/dev/pve/vm-${target_id}-disk-0"
    cat > "$CONFIG_FILE" <<EOF
VM_NAME=$vm
SRC_DISK=
QEMU_DEVICE=
QEMU_NODE=
BITMAP=$(default_bitmap "$vm")
TARGET_NODE=$(default_target_node "$vm")
TARGET_HOST=$target_host
TARGET_SSH_USER=root
TARGET_SSH_PORT=$ssh_port
TARGET_ID=$target_id
TARGET_DISK=$target_disk
NBD_PORT=10809
NBD_EXPORT=vm-${target_id}
TUNNEL_MODE=autossh
AUTOSSH_MONITOR_PORT=20000
BACKUP_METHOD=drive-backup
EOF
    chmod 600 "$CONFIG_FILE"
  fi
}

show_config(){
  load_config
  cat <<EOF
Source VM      : $VM_NAME
Source disk    : ${SRC_DISK:-not set}
QEMU device    : ${QEMU_DEVICE:-not set}
QEMU node      : ${QEMU_NODE:-not set}
Bitmap         : $BITMAP
Target node    : $TARGET_NODE
Target         : ${TARGET_SSH_USER}@${TARGET_HOST}:${TARGET_SSH_PORT}
Target ID      : $TARGET_ID
Target disk    : $TARGET_DISK
NBD            : 127.0.0.1:${NBD_PORT}, export=${NBD_EXPORT}
Tunnel mode    : $TUNNEL_MODE
Backup method  : ${BACKUP_METHOD:-drive-backup}
QMP timeout    : ${QMP_TIMEOUT:-20}s
Check timeout  : ${CHECK_TIMEOUT:-8}s
NBD I/O timeout: ${NBD_IO_TIMEOUT:-20}s
EOF
}

apply_handoff(){
  local token="${1:-}" prefix="VMIGRATE_HANDOFF_V1:" payload decoded line key val
  local handoff_target_id="" handoff_target_disk="" handoff_nbd_port="" handoff_nbd_export=""

  [[ -n "$token" ]] || die "Missing handoff token"
  [[ "$token" == "$prefix"* ]] || die "Invalid handoff token prefix"
  need base64

  payload="${token#"$prefix"}"
  [[ -n "$payload" ]] || die "Missing handoff payload"
  decoded="$(printf '%s' "$payload" | base64 -d 2>/dev/null)" || die "Failed to decode handoff payload"

  while IFS= read -r line || [[ -n "$line" ]]; do
    [[ -n "$line" ]] || continue
    [[ "$line" == *=* ]] || continue
    key="${line%%=*}"
    val="${line#*=}"
    case "$key" in
      TARGET_ID) handoff_target_id="$val" ;;
      TARGET_DISK) handoff_target_disk="$val" ;;
      NBD_PORT) handoff_nbd_port="$val" ;;
      NBD_EXPORT) handoff_nbd_export="$val" ;;
      *) ;;
    esac
  done <<EOF
$decoded
EOF

  [[ -n "$handoff_target_id" ]] || die "Handoff payload missing TARGET_ID"
  [[ -n "$handoff_target_disk" ]] || die "Handoff payload missing TARGET_DISK"
  [[ -n "$handoff_nbd_port" ]] || handoff_nbd_port="10809"
  [[ -n "$handoff_nbd_export" ]] || handoff_nbd_export="vm-${handoff_target_id}"

  write_key TARGET_ID "$handoff_target_id"
  write_key TARGET_DISK "$handoff_target_disk"
  write_key NBD_PORT "$handoff_nbd_port"
  write_key NBD_EXPORT "$handoff_nbd_export"

  cat <<EOF
Applied handoff
---------------
TARGET_ID=$handoff_target_id
TARGET_DISK=$handoff_target_disk
NBD_PORT=$handoff_nbd_port
NBD_EXPORT=$handoff_nbd_export
EOF
}

conf_present(){ [[ -n "$(get_conf "$1")" ]]; }
conf_value(){ local val; val="$(get_conf "$1")"; printf '%s' "${val:-$2}"; }
status_word(){ if "$@"; then printf 'yes'; else printf 'no'; fi; }

prompt_source_vm(){
  local current_vm vm
  current_vm="$(conf_value VM_NAME kvm3023)"
  ask vm "Source VM name" "$current_vm"
  printf '%s' "$vm"
}

prompt_pve_connection(){
  local target_host ssh_port

  target_host="$(conf_value TARGET_HOST CHANGE_ME)"
  ask target_host "Target host/IP" "$target_host"
  write_key TARGET_HOST "$target_host"

  ssh_port="$(conf_value TARGET_SSH_PORT 22)"
  ask ssh_port "Target SSH port" "$ssh_port"
  write_key TARGET_SSH_PORT "$ssh_port"

  [[ -n "$(get_conf TARGET_SSH_USER)" ]] || write_key TARGET_SSH_USER root
}

source_discovered(){ conf_present SRC_DISK && conf_present QEMU_DEVICE && conf_present QEMU_NODE; }
handoff_applied(){ conf_present TARGET_ID && conf_present TARGET_DISK && conf_present NBD_PORT && conf_present NBD_EXPORT; }
target_host_set(){ local host; host="$(get_conf TARGET_HOST)"; [[ -n "$host" && "$host" != "CHANGE_ME" ]]; }

next_steps(){
  local vm target_host method effective full_started full_completed final_completed source_stopped bitmap_ok tunnel_ok

  if [[ ! -f "$CONFIG_FILE" ]]; then
    cat <<EOF
Current state
-------------
Config file    : missing

Next (recommended):
./vmigrate quick HANDOFF_TOKEN
EOF
    return 0
  fi

  vm="$(conf_value VM_NAME VM_NAME)"
  target_host="$(conf_value TARGET_HOST CHANGE_ME)"
  method="$(conf_value BACKUP_METHOD drive-backup)"
  full_started="$(state_get FULL_STARTED)"; full_started="${full_started:-0}"
  full_completed="$(state_get FULL_COMPLETED)"; full_completed="${full_completed:-0}"
  final_completed="$(state_get FINAL_COMPLETED)"; final_completed="${final_completed:-0}"
  source_stopped="$(state_get SOURCE_STOPPED)"; source_stopped="${source_stopped:-0}"

  if source_discovered && handoff_applied && target_host_set; then
    load_config
    effective="$(effective_backup_method)"
    if tunnel_health_ok >/dev/null 2>&1; then tunnel_ok="yes"; else tunnel_ok="no"; fi
    if bitmap_exists >/dev/null 2>&1; then bitmap_ok="yes"; else bitmap_ok="no"; fi
  else
    effective="$method"
    tunnel_ok="unknown"
    bitmap_ok="unknown"
  fi

  cat <<EOF
Current state
-------------
Config file       : $CONFIG_FILE
VM name           : $vm
Backup method     : $method
Effective method  : $effective
Source discovered : $(status_word source_discovered)
Handoff applied   : $(status_word handoff_applied)
Target host set   : $(status_word target_host_set) ($target_host)
Tunnel healthy    : $tunnel_ok
Bitmap present    : $bitmap_ok
FULL_STARTED      : $full_started
FULL_COMPLETED    : $full_completed
FINAL_COMPLETED   : $final_completed
SOURCE_STOPPED    : $source_stopped

Suggested next
--------------
EOF

  if ! conf_present VM_NAME; then
    echo "./vmigrate discover VM_NAME"
  elif ! source_discovered; then
    echo "./vmigrate discover $vm"
  elif ! handoff_applied; then
    echo "./vmigrate apply-handoff HANDOFF_TOKEN"
  elif ! target_host_set; then
    echo "Set TARGET_HOST in $CONFIG_FILE, then run: ./vmigrate remote-prepare or ./vmigrate doctor"
  elif [[ "$tunnel_ok" != "yes" ]]; then
    echo "./vmigrate remote-export"
    echo "./vmigrate tunnel"
    echo "./vmigrate tunnel-check"
  elif [[ "$bitmap_ok" != "yes" ]]; then
    if [[ "$effective" == "blockdev-backup" ]]; then
      echo "./vmigrate attach-target"
      echo "./vmigrate check-target"
    fi
    echo "./vmigrate bitmap"
    echo "./vmigrate check-bitmap"
  elif [[ "$full_started" != "1" ]]; then
    echo "./vmigrate full"
  elif [[ "$full_completed" != "1" ]]; then
    echo "./vmigrate wait-full"
  elif [[ "$final_completed" != "1" ]]; then
    echo "./vmigrate cutover-check"
    echo "./vmigrate final"
  elif [[ "$source_stopped" != "1" ]]; then
    echo "./vmigrate stop-source"
  else
    echo "./vmigrate remote-dst-close"
  fi
}

quick_start(){
  local vm_arg="${1:-}" token="${2:-}"

  if [[ "$vm_arg" == VMIGRATE_HANDOFF_V1:* && -z "$token" ]]; then
    token="$vm_arg"
    vm_arg=""
  fi

  if [[ -n "$token" ]]; then
    apply_handoff "$token"
    [[ -n "$vm_arg" ]] || vm_arg="$(prompt_source_vm)"
    prompt_pve_connection
    discover "$vm_arg"
  else
    warn "No handoff token supplied; run apply-handoff before doctor if destination values changed"
    discover "$vm_arg"
  fi

  show_config

  if confirm "Run source doctor now?"; then
    preflight
  else
    warn "Preflight skipped"
  fi

  echo
  next_steps
}

remote_dir(){ printf '/root/vmigrate'; }
remote_ssh(){
  ssh -p "$TARGET_SSH_PORT" -o BatchMode=yes -o ConnectTimeout=8 "$TARGET_SSH_USER@$TARGET_HOST" "$@"
}
remote_ssh_batch(){
  remote_ssh "$@"
}

remote_prepare_next_steps(){
  load_config
  local effective
  effective="$(effective_backup_method)"
  cat <<EOF

Destination is prepared remotely.
Now run:

./vmigrate set-backup-method
./vmigrate doctor
./vmigrate remote-export
./vmigrate tunnel
./vmigrate tunnel-check
EOF
  if [[ "$effective" == "blockdev-backup" ]]; then
    cat <<EOF
./vmigrate attach-target
./vmigrate check-target
EOF
  fi
  cat <<EOF
./vmigrate bitmap
./vmigrate check-bitmap
./vmigrate full
./vmigrate wait-full
./vmigrate report

Optional monitor in another terminal:
./vmigrate watch
EOF
}

remote_prepare(){
  local vm="${1:-}" target_host="${2:-}" target_id="${3:-}" ssh_port="${4:-22}" ssh_user="${5:-root}"
  local dst_script rdir token prefix="VMIGRATE_HANDOFF_V1:"

  [[ -n "$vm" && -n "$target_host" && -n "$target_id" ]] || die "Usage: ./vmigrate remote-prepare VM_NAME TARGET_ID TARGET_HOST [SSH_PORT] [SSH_USER]"
  case "$target_id" in *[!0-9]*|'') die "Target ID must be numeric" ;; esac
  case "$ssh_port" in *[!0-9]*|'') die "SSH port must be numeric" ;; esac
  [[ -f "$SCRIPT_DIR/vmigrate" ]] || die "Source helper missing: $SCRIPT_DIR/vmigrate"
  dst_script="$SCRIPT_DIR/vmigrate-agent"
  [[ -f "$dst_script" ]] || die "Destination helper missing: $dst_script"

  write_key VM_NAME "$vm"
  write_key TARGET_HOST "$target_host"
  write_key TARGET_SSH_USER "$ssh_user"
  write_key TARGET_SSH_PORT "$ssh_port"
  write_key TARGET_ID "$target_id"
  [[ -n "$(get_conf BITMAP)" ]] || write_key BITMAP "$(default_bitmap "$vm")"
  [[ -n "$(get_conf TARGET_NODE)" ]] || write_key TARGET_NODE "$(default_target_node "$vm")"
  [[ -n "$(get_conf NBD_PORT)" ]] || write_key NBD_PORT 10809
  write_key NBD_EXPORT "vm-${target_id}"
  [[ -n "$(get_conf TUNNEL_MODE)" ]] || write_key TUNNEL_MODE autossh
  [[ -n "$(get_conf AUTOSSH_MONITOR_PORT)" ]] || write_key AUTOSSH_MONITOR_PORT 20000
  [[ -n "$(get_conf BACKUP_METHOD)" ]] || write_key BACKUP_METHOD drive-backup

  # shellcheck disable=SC1090
  source "$CONFIG_FILE"
  rdir="$(remote_dir)"

  need ssh
  need scp
  info "Testing SSH connectivity to ${TARGET_SSH_USER}@${TARGET_HOST}:${TARGET_SSH_PORT}"
  remote_ssh_batch true >/dev/null || die "Cannot connect to destination over SSH: ${TARGET_SSH_USER}@${TARGET_HOST}:${TARGET_SSH_PORT}"

  info "Creating remote workspace: $rdir"
  remote_ssh "mkdir -p '$rdir'" || die "Could not create remote workspace: $rdir"

  info "Copying destination helper"
  scp -P "$TARGET_SSH_PORT" -o BatchMode=yes -o ConnectTimeout=8 "$dst_script" "${TARGET_SSH_USER}@${TARGET_HOST}:${rdir}/vmigrate-agent" || die "Could not copy destination helper"
  remote_ssh "chmod +x '$rdir/vmigrate-agent'" || die "Could not make destination helper executable"

  info "Discovering target ID $TARGET_ID"
  remote_ssh "cd '$rdir' && ./vmigrate-agent discover '$TARGET_ID' --yes" || die "Remote destination discover failed"

  info "Reading destination handoff token"
  token="$(remote_ssh "cd '$rdir' && ./vmigrate-agent handoff")" || die "Remote destination handoff failed"
  [[ "$token" == "$prefix"* ]] || die "Remote handoff token is invalid"

  apply_handoff "$token"
  info "Running source discovery and writing SRC_DISK/QEMU_DEVICE/QEMU_NODE when unambiguous"
  discover "$VM_NAME" --yes
  # shellcheck disable=SC1090
  source "$CONFIG_FILE"
  [[ -n "${SRC_DISK:-}" && ( -b "$SRC_DISK" || -f "$SRC_DISK" ) && -n "${QEMU_DEVICE:-}" && -n "${QEMU_NODE:-}" ]] || die "Source discovery did not write valid SRC_DISK/QEMU_DEVICE/QEMU_NODE. Run: ./vmigrate discover $VM_NAME"
  show_config
  remote_prepare_next_steps
}

remote_export_once(){
  local allow_stop="${1:-0}" env_prefix=""
  [[ "$allow_stop" == "1" ]] && env_prefix="VMIGRATE_ALLOW_STOP_TARGET=1 "
  remote_ssh "cd '$(remote_dir)' && ./vmigrate-agent doctor && ${env_prefix}./vmigrate-agent export && ./vmigrate-agent status"
}

remote_export(){
  load_config
  need ssh

  local out rc attempt allow_stop=0 did_cleanup=0

  for attempt in 1 2 3; do
    set +e
    out="$(remote_export_once "$allow_stop" 2>&1)"
    rc=$?
    set -e

    printf '%s\n' "$out"

    if [[ "$rc" == "0" ]]; then
      return 0
    fi

    if [[ "$allow_stop" != "1" ]] && printf '%s\n' "$out" | grep -q "Target VM .* is running"; then
      warn "Destination target VM appears to be running."
      if ask_yes_default "Stop the destination VM remotely and retry NBD export?"; then
        allow_stop=1
        continue
      fi
      die "Remote export failed because destination VM is running."
    fi

    if [[ "$did_cleanup" != "1" ]] && printf '%s\n' "$out" | grep -q "NBD port already in use"; then
      warn "Remote NBD export port appears to be already in use."
      if ask_yes_default "Close remote NBD export, stop local tunnel, and retry remote-export?"; then
        did_cleanup=1
        tunnel_stop || warn "Local tunnel stop failed or no tunnel was found."
        remote_dst_close || warn "Remote NBD close failed or no export was found."
        continue
      fi
      die "Remote export failed because NBD port is already in use."
    fi

    return "$rc"
  done

  die "Remote export failed after recovery attempts."
}

remote_dst_status(){
  load_config
  need ssh
  remote_ssh "cd '$(remote_dir)' && ./vmigrate-agent status"
}

remote_dst_close(){
  load_config
  need ssh
  remote_ssh "cd '$(remote_dir)' && ./vmigrate-agent close"
}

qmp(){ local json="$1"; timeout "${QMP_TIMEOUT:-20}" virsh qemu-monitor-command "$VM_NAME" --pretty "$json"; }

parse_info_block(){
  awk '
    /^[^[:space:]:]+[[:space:]]+\(#block[0-9]+\):/ {
      device=$1
      node=$2; gsub(/[():]/,"",node)
      disk=$0; sub(/^[^:]+:[[:space:]]*/,"",disk); sub(/[[:space:]]+\([^)]+\).*$/,"",disk)
      print device "\t" node "\t" disk
    }
  '
}

block_jobs_json(){ load_config; qmp '{"execute":"query-block-jobs"}'; }
block_jobs_empty(){
  local out
  out="$(block_jobs_json 2>/dev/null)" || return 1
  if printf '%s\n' "$out" | grep -q '"error"'; then
    printf '%s\n' "$out" >&2
    return 1
  fi
  ! printf '%s\n' "$out" | grep -q '"type"'
}
block_jobs_query_ok_empty(){
  local out
  out="$(block_jobs_json 2>/dev/null)" || return 1
  if printf '%s\n' "$out" | grep -q '"error"'; then
    printf '%s\n' "$out"
    return 1
  fi
  ! printf '%s\n' "$out" | grep -q '"type"'
}
block_job_ids_from_json(){ awk -F'"' '/"device"/ {print $4}'; }
block_jobs_table_from_json(){
  awk -F'"' '
    /"device"/ {device=$4}
    /"status"/ {status=$4}
    /}/ {
      if (device != "") {
        if (status == "") status="unknown"
        print device "\t" status
      }
      device=""; status=""
    }'
}
block_jobs_summary(){
  awk -F'[:,]' '
    /"device"/ {gsub(/[ "]/,"",$2); device=$2}
    /"status"/ {gsub(/[ "]/,"",$2); status=$2}
    /"offset"/ {gsub(/[^0-9]/,"",$2); offset=$2}
    /"len"/ {gsub(/[^0-9]/,"",$2); len=$2}
    /}/ {
      if (device != "") {
        pct="n/a"; if (len > 0) pct=int((offset*100)/len) "%"
        printf "Job %s: status=%s progress=%s offset=%s len=%s\n", device, status, pct, offset, len
      }
      device=""; status=""; offset=""; len=""
    }'
}

progress_line(){
  local offset="${1:-0}" len="${2:-0}" status="${3:-running}" width=30 pct filled empty bar
  if [[ "$len" =~ ^[0-9]+$ && "$offset" =~ ^[0-9]+$ && "$len" -gt 0 ]]; then
    pct=$(( offset * 100 / len ))
    (( pct > 100 )) && pct=100
    filled=$(( pct * width / 100 ))
    empty=$(( width - filled ))
  else
    pct=0
    filled=0
    empty=$width
  fi
  bar="$(printf '%*s' "$filled" '' | tr ' ' '#')$(printf '%*s' "$empty" '' | tr ' ' '-')"
  printf '[%s] %d%% | %s | %s / %s' "$bar" "$pct" "$status" "${offset:-0}" "${len:-0}"
}

progress_from_jobs_json(){
  awk '
    /"offset"/ {gsub(/[^0-9]/,"",$2); offset=$2}
    /"len"/ {gsub(/[^0-9]/,"",$2); len=$2}
    /"status"/ {gsub(/[",]/,"",$2); status=$2}
    END {printf "%s\t%s\t%s\n", offset, len, status}'
}
wait_jobs_empty(){
  load_config
  local out job status parsed_status progress offset len compact=0 compact_printed=0
  if [[ -t 1 && "${DEBUG:-0}" != "1" ]]; then
    compact=1
  fi
  while true; do
    out="$(block_jobs_json)" || {
      (( compact_printed )) && printf '\n'
      die "QMP query timed out or failed while waiting for block jobs"
    }
    if printf '%s\n' "$out" | grep -q '"error"'; then
      (( compact_printed )) && printf '\n'
      printf '%s\n' "$out"
      die "Block job ended with an error"
    fi
    if ! printf '%s\n' "$out" | grep -q '"type"'; then
      (( compact_printed )) && printf '\n'
      ok "No active block job"
      return 0
    fi
    status="$(printf '%s\n' "$out" | awk -F'"' '/"status"/ {print $4; exit}')"
    job="$(printf '%s\n' "$out" | awk -F'"' '/"device"/ {print $4; exit}')"
    IFS=$'\t' read -r offset len parsed_status <<< "$(printf '%s\n' "$out" | progress_from_jobs_json)"
    [[ -n "$parsed_status" ]] && status="$parsed_status"
    progress="$(progress_line "$offset" "$len" "${status:-running}")"
    if (( compact )); then
      printf '\r%s' "$progress"
      compact_printed=1
    else
      printf '%s\n' "$progress"
    fi
    if [[ "$status" == "concluded" ]]; then
      (( compact_printed )) && printf '\n'
      if [[ -n "$job" ]]; then
        job_dismiss "$job" || warn "Could not dismiss concluded job: $job"
      fi
      ok "Block job concluded"
      return 0
    fi
    sleep 2
  done
}

bitmap_exists(){ load_config; qmp '{"execute":"query-block"}' 2>/dev/null | grep -q "\"name\": \"$BITMAP\""; }
target_node_exists(){ load_config; qmp '{"execute":"query-named-block-nodes"}' 2>/dev/null | grep -q "\"node-name\": \"$TARGET_NODE\""; }

