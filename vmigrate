#!/usr/bin/env bash
# vmigrate source-side helper
set -Eeuo pipefail

VERSION="1.0.1"
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
DEFAULT_CONFIG_FILE="${SCRIPT_DIR}/vmigrate.env"
ACTIVE_FILE="${SCRIPT_DIR}/.vmigrate-active"

active_run_dir(){
  local target
  if [[ -L "$ACTIVE_FILE" ]]; then
    target="$(readlink "$ACTIVE_FILE")" || return 1
  elif [[ -f "$ACTIVE_FILE" ]]; then
    target="$(cat "$ACTIVE_FILE")" || return 1
  else
    return 1
  fi
  [[ -n "$target" ]] || return 1
  case "$target" in
    /*) printf '%s\n' "$target" ;;
    *) printf '%s/%s\n' "$SCRIPT_DIR" "$target" ;;
  esac
}

resolve_config_file(){
  local active_dir
  if [[ -n "${VMIGRATE_CONFIG:-}" ]]; then
    printf '%s\n' "$VMIGRATE_CONFIG"
    return 0
  fi
  if active_dir="$(active_run_dir 2>/dev/null)" && [[ -f "$active_dir/config" ]]; then
    printf '%s\n' "$active_dir/config"
    return 0
  fi
  printf '%s\n' "$DEFAULT_CONFIG_FILE"
}

CONFIG_FILE="$(resolve_config_file)"

RED=$'\033[0;31m'; GREEN=$'\033[0;32m'; YELLOW=$'\033[1;33m'; BLUE=$'\033[0;34m'; NC=$'\033[0m'
if [[ -n "${NO_COLOR:-}" ]]; then
  RED=""; GREEN=""; YELLOW=""; BLUE=""; NC=""
fi
info(){ echo "${BLUE}>>${NC} $*"; }
ok(){ echo "${GREEN}OK${NC} $*"; }
warn(){ echo "${YELLOW}WARN${NC} $*"; }
die(){ echo "${RED}ERROR${NC} $*" >&2; exit 1; }
need(){ command -v "$1" >/dev/null 2>&1 || die "Required command not found: $1"; }

