block_jobs_table_from_json(){
  awk -F'"' '
    /"device"/ {device=$4}
    /"status"/ {status=$4}
    /}/ {
      if (device != "") {
        if (status == "") status="unknown"
        print device "\t" status
      }
      device=""; status=""
    }'
}
block_jobs_summary(){
  awk -F'[:,]' '
    /"device"/ {gsub(/[ "]/,"",$2); device=$2}
    /"status"/ {gsub(/[ "]/,"",$2); status=$2}
    /"offset"/ {gsub(/[^0-9]/,"",$2); offset=$2}
    /"len"/ {gsub(/[^0-9]/,"",$2); len=$2}
    /}/ {
      if (device != "") {
        pct="n/a"; if (len > 0) pct=int((offset*100)/len) "%"
        printf "Job %s: status=%s progress=%s offset=%s len=%s\n", device, status, pct, offset, len
      }
      device=""; status=""; offset=""; len=""
    }'
}

PROGRESS_START_TS=0
PROGRESS_START_OFFSET=0
PROGRESS_TRACK_LEN=0

format_bytes(){
  local bytes="${1:-0}"
  awk -v b="$bytes" 'BEGIN {
    split("B KiB MiB GiB TiB PiB", u, " ")
    i = 1
    while (b >= 1024 && i < 6) {
      b = b / 1024
      i++
    }
    if (i == 1) {
      printf "%.0f %s", b, u[i]
    } else {
      printf "%.1f %s", b, u[i]
    }
  }'
}

format_duration(){
  local sec="${1:-0}" h m s
  [[ "$sec" =~ ^[0-9]+$ ]] || { printf 'n/a'; return 0; }
  h=$(( sec / 3600 ))
  m=$(( (sec % 3600) / 60 ))
  s=$(( sec % 60 ))
  printf '%02d:%02d:%02d' "$h" "$m" "$s"
}



format_bytes_short(){
  local h="$1"

  h="${h/.0 GiB/G}"
  h="${h/.0 MiB/M}"
  h="${h/.0 KiB/K}"

  h="${h// GiB/G}"
  h="${h// MiB/M}"
  h="${h// KiB/K}"

  printf '%s\n' "$h"
}

# Select progress layout based on terminal width.
progress_layout(){
  local cols="${1:-${COLUMNS:-120}}"

  if [[ -t 1 ]]; then
    if command -v stty >/dev/null 2>&1; then
      cols="$(stty size 2>/dev/null | awk '{print $2}')"
    fi
    if ! [[ "$cols" =~ ^[0-9]+$ ]] && command -v tput >/dev/null 2>&1; then
      cols="$(tput cols 2>/dev/null || echo "$cols")"
    fi
  fi

  [[ "$cols" =~ ^[0-9]+$ ]] || cols=120

  if (( cols >= 140 )); then
    printf 'full\n'
    return
  fi

  if (( cols >= 110 )); then
    printf 'compact\n'
    return
  fi

  if (( cols >= 80 )); then
    printf 'short\n'
    return
  fi

  if (( cols >= 60 )); then
    printf 'tiny\n'
    return
  fi

  printf 'minimal\n'
}

progress_line(){
  local offset="${1:-0}" len="${2:-0}" status="${3:-running}" width=30
  local pct filled empty bar now elapsed delta speed remaining eta
  local offset_h len_h speed_h elapsed_h eta_h

  if [[ "$len" =~ ^[0-9]+$ && "$offset" =~ ^[0-9]+$ && "$len" -gt 0 ]]; then
    pct=$(( offset * 100 / len ))
    (( pct > 100 )) && pct=100
    filled=$(( pct * width / 100 ))
    empty=$(( width - filled ))

    now="$(date +%s)"

    if [[ "$PROGRESS_START_TS" -eq 0 || "$PROGRESS_TRACK_LEN" != "$len" || "$offset" -lt "$PROGRESS_START_OFFSET" ]]; then
      PROGRESS_START_TS="$now"
      PROGRESS_START_OFFSET="$offset"
      PROGRESS_TRACK_LEN="$len"
    fi

    elapsed=$(( now - PROGRESS_START_TS ))
    delta=$(( offset - PROGRESS_START_OFFSET ))

    elapsed_h="$(format_duration "$elapsed")"

    if [[ "$elapsed" -gt 0 && "$delta" -gt 0 ]]; then
      speed=$(( delta / elapsed ))
      remaining=$(( len - offset ))
      (( remaining < 0 )) && remaining=0

      if [[ "$speed" -gt 0 ]]; then
        eta=$(( remaining / speed ))
        speed_h="$(format_bytes "$speed")/s"
        eta_h="$(format_duration "$eta")"
      else
        speed_h="n/a"
        eta_h="n/a"
      fi
    else
      speed_h="n/a"
      eta_h="n/a"
    fi

    offset_h="$(format_bytes "$offset")"
    len_h="$(format_bytes "$len")"
  else
    pct=0
    filled=0
    empty=$width
    offset_h="${offset:-0}"
    len_h="${len:-0}"
    speed_h="n/a"
    elapsed_h="00:00:00"
    eta_h="n/a"
  fi

  cols="${COLUMNS:-120}"
  layout="$(progress_layout "$cols")"

  case "$layout" in
    full)    width=30 ;;
    compact) width=20 ;;
    short)   width=10 ;;
    *)        width=0 ;;
  esac

  if (( width > 0 )); then
    filled=$(( pct * width / 100 ))
    empty=$(( width - filled ))
    bar="$(printf '%*s' "$filled" '' | tr ' ' '#')$(printf '%*s' "$empty" '' | tr ' ' '-')"
  fi

  offset_short="$offset_h"
  len_short="$len_h"
  speed_short="$speed_h"

  offset_short="${offset_short/.0 GiB/G}"
  offset_short="${offset_short/.0 MiB/M}"
  offset_short="${offset_short/.0 KiB/K}"
  offset_short="${offset_short// GiB/G}"
  offset_short="${offset_short// MiB/M}"
  offset_short="${offset_short// KiB/K}"

  len_short="${len_short/.0 GiB/G}"
  len_short="${len_short/.0 MiB/M}"
  len_short="${len_short/.0 KiB/K}"
  len_short="${len_short// GiB/G}"
  len_short="${len_short// MiB/M}"
  len_short="${len_short// KiB/K}"

  speed_short="${speed_short/.0 MiB\/s/M/s}"
  speed_short="${speed_short// MiB\/s/M/s}"

  case "$layout" in

    full)
      if [[ "$status" == "running" ]]; then
        line="[$bar] ${pct}% | ${offset_h} / ${len_h} | ${speed_h} | elapsed ${elapsed_h} | ETA ${eta_h}"
      else
        line="[$bar] ${pct}% | ${status} | ${offset_h} / ${len_h} | ${speed_h} | elapsed ${elapsed_h} | ETA ${eta_h}"
      fi
      ;;

    compact)
      line="[$bar] ${pct}% | ${offset_short}/${len_short} | ${speed_short} | ETA ${eta_h}"
      ;;

    short)
      line="[$bar] ${pct}% | ${offset_short}/${len_short} | ETA ${eta_h}"
      ;;

    tiny)
      line="${pct}% | ${offset_short}/${len_short} | ETA ${eta_h}"
      ;;

    *)
      if [[ "$eta_h" != "n/a" ]]; then
        line="${pct}% | ETA ${eta_h}"
      else
        line="${pct}%"
      fi
      ;;

  esac

  # Never let progress wrap when terminal/window becomes narrow.
  [[ "$cols" =~ ^[0-9]+$ ]] || cols=80
  if (( cols > 1 && ${#line} >= cols )); then
    line="${line:0:$((cols-1))}"
  fi

  printf '%s' "$line"
}

progress_from_jobs_json(){
  awk '
    /"offset"/ {gsub(/[^0-9]/,"",$2); offset=$2}
    /"len"/ {gsub(/[^0-9]/,"",$2); len=$2}
    /"status"/ {gsub(/[",]/,"",$2); status=$2}
    END {printf "%s\t%s\t%s\n", offset, len, status}'
}
wait_jobs_empty(){
  load_config
  local out job status parsed_status progress offset len compact=0 compact_printed=0
  local qmp_failures=0 qmp_max_failures="${VMIGRATE_QMP_WAIT_RETRIES:-5}"
  if [[ "${DEBUG:-0}" != "1" ]] && { [[ -t 1 ]] || [[ "${VMIGRATE_PROGRESS_COMPACT:-0}" == "1" ]]; }; then
    compact=1
  fi
  while true; do
    out="$(block_jobs_json)" || {
      qmp_failures=$((qmp_failures + 1))
      if (( qmp_failures <= qmp_max_failures )); then
        (( compact_printed )) && printf '\n'
        warn "QMP query timed out while waiting for block jobs; retrying ${qmp_failures}/${qmp_max_failures}"
        sleep 3
        continue
      fi
      (( compact_printed )) && printf '\n'
      die "QMP query timed out or failed while waiting for block jobs"
    }
    qmp_failures=0
    if printf '%s\n' "$out" | grep -q '"error"'; then
      (( compact_printed )) && printf '\n'
      printf '%s\n' "$out"
      die "Block job ended with an error"
    fi
    if ! printf '%s\n' "$out" | grep -q '"type"'; then
      (( compact_printed )) && printf '\n'
      ok "No active block job"
      return 0
    fi
    status="$(printf '%s\n' "$out" | awk -F'"' '/"status"/ {print $4; exit}')"
    job="$(printf '%s\n' "$out" | awk -F'"' '/"device"/ {print $4; exit}')"
    IFS=$'\t' read -r offset len parsed_status <<< "$(printf '%s\n' "$out" | progress_from_jobs_json)"
    [[ -n "$parsed_status" ]] && status="$parsed_status"
    if (( compact )); then
      printf '\r\033[K'
      progress_line "$offset" "$len" "${status:-running}"
      compact_printed=1
    else
      progress_line "$offset" "$len" "${status:-running}"
      printf '\n'
    fi
    if [[ "$status" == "concluded" ]]; then
      (( compact_printed )) && printf '\n'
      if [[ -n "$job" ]]; then
        job_dismiss "$job" || warn "Could not dismiss concluded job: $job"
      fi
      ok "Block job concluded"
      return 0
    fi
    sleep 2
  done
}

bitmap_exists(){ load_config; qmp '{"execute":"query-block"}' 2>/dev/null | grep -q "\"name\": \"$BITMAP\""; }
target_node_exists(){ load_config; qmp '{"execute":"query-named-block-nodes"}' 2>/dev/null | grep -q "\"node-name\": \"$TARGET_NODE\""; }

